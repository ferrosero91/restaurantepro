<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reporte de Clientes - RestaurantPro</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/static/css/theme.css">
    <link rel="stylesheet" href="/static/css/reportes.css">
    <style>
        .cliente-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--rp-slate-800);
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.9rem;
            flex-shrink: 0;
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="rp-content">

    <main class="py-2">
        <div class="container-fluid px-3 px-md-4">

            <%- include('../partials/breadcrumbs', { items: [
                { label: 'Reportes', href: '/reportes' },
                { label: 'Top Clientes' }
            ] }) %>

            <ul class="nav nav-tabs" role="tablist" aria-label="Secciones de reportes">
                <li class="nav-item" role="presentation">
                    <a class="nav-link" href="/reportes" role="tab">
                        <i class="bi bi-speedometer2" aria-hidden="true"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" href="/reportes#historial" role="tab">
                        <i class="bi bi-receipt" aria-hidden="true"></i>Historial
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" href="/reportes/productos" role="tab">
                        <i class="bi bi-box-seam" aria-hidden="true"></i>Top Productos
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link active" href="/reportes/clientes" role="tab" aria-selected="true">
                        <i class="bi bi-people" aria-hidden="true"></i>Top Clientes
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" href="/reportes/propinas" role="tab">
                        <i class="bi bi-cash-coin" aria-hidden="true"></i>Propinas
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" href="/reportes/domicilios" role="tab">
                        <i class="bi bi-truck" aria-hidden="true"></i>Domicilios
                    </a>
                </li>
            </ul>

            <div class="table-card">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th width="60">Ranking</th>
                                <th>Cliente</th>
                                <th>Contacto</th>
                                <th class="text-end">Total Compras</th>
                                <th class="text-end">Ticket Promedio</th>
                                <th class="text-end">Total Gastado</th>
                                <th>Última Compra</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (clientes.length === 0) { %>
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-5">
                                        <div class="empty-state">
                                            <i class="bi bi-inbox"></i>
                                            <h5>No hay datos disponibles</h5>
                                            <p>No hay datos de clientes en el período seleccionado</p>
                                        </div>
                                    </td>
                                </tr>
                            <% } else { %>
                                <% clientes.forEach((cliente, index) => { %>
                                    <tr>
                                        <td>
                                            <span class="badge-rank <%= index === 0 ? 'gold' : index === 1 ? 'silver' : index === 2 ? 'bronze' : 'other' %>">
                                                <%= index + 1 %>
                                            </span>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="cliente-avatar">
                                                    <%= cliente.nombre.charAt(0).toUpperCase() %>
                                                </div>
                                                <strong><%= cliente.nombre %></strong>
                                            </div>
                                        </td>
                                        <td>
                                            <% if (cliente.telefono) { %>
                                                <i class="bi bi-telephone me-1"></i><%= cliente.telefono %>
                                            <% } else { %>
                                                <span class="text-muted">Sin teléfono</span>
                                            <% } %>
                                        </td>
                                        <td class="text-end">
                                            <span class="badge bg-primary"><%= cliente.total_compras %></span>
                                        </td>
                                        <td class="text-end">
                                            $<%= Number(cliente.ticket_promedio).toLocaleString('es-CO', {minimumFractionDigits:2}) %>
                                        </td>
                                        <td class="text-end">
                                            <strong>$<%= Number(cliente.total_gastado).toLocaleString('es-CO', {minimumFractionDigits:2}) %></strong>
                                        </td>
                                        <td>
                                            <small class="text-muted">
                                                <%= new Date(cliente.ultima_compra).toLocaleDateString('es-CO', {year: 'numeric', month: 'short', day: 'numeric'}) %>
                                            </small>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    </div>
<%- include('../partials/toasts') %>
</body>
</html>