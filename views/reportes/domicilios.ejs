<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reportes Domicilios - RestaurantPro</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/static/css/theme.css">
    <link rel="stylesheet" href="/static/css/reportes.css">
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="rp-content">
    
    <main class="py-2">
        <div class="container-fluid px-3 px-md-4">

            <%- include('../partials/breadcrumbs', { items: [
                { label: 'Reportes', href: '/reportes' },
                { label: 'Domicilios' }
            ] }) %>

            <ul class="nav nav-tabs" role="tablist" aria-label="Secciones de reportes">
                <li class="nav-item" role="presentation">
                    <a class="nav-link" href="/reportes" role="tab">
                        <i class="bi bi-speedometer2" aria-hidden="true"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" href="/reportes#historial" role="tab">
                        <i class="bi bi-receipt" aria-hidden="true"></i>Historial
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" href="/reportes/productos" role="tab">
                        <i class="bi bi-box-seam" aria-hidden="true"></i>Top Productos
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" href="/reportes/clientes" role="tab">
                        <i class="bi bi-people" aria-hidden="true"></i>Top Clientes
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" href="/reportes/propinas" role="tab">
                        <i class="bi bi-cash-coin" aria-hidden="true"></i>Propinas
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link active" href="/reportes/domicilios" role="tab" aria-selected="true">
                        <i class="bi bi-truck" aria-hidden="true"></i>Domicilios
                    </a>
                </li>
            </ul>

            <!-- Filtros -->
            <div class="rp-card mb-4">
                <div class="rp-card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label class="rp-label" for="fechaDesde">
                                <i class="bi bi-calendar-event me-1"></i>Fecha Desde
                            </label>
                            <input type="date" id="fechaDesde" class="rp-input" value="<%= filtros.desde %>">
                        </div>
                        <div class="col-md-3">
                            <label class="rp-label" for="fechaHasta">
                                <i class="bi bi-calendar-check me-1"></i>Fecha Hasta
                            </label>
                            <input type="date" id="fechaHasta" class="rp-input" value="<%= filtros.hasta %>">
                        </div>
                        <div class="col-md-6">
                            <button class="rp-btn rp-btn-primary me-2" onclick="aplicarFiltros()">
                                <i class="bi bi-funnel"></i>Aplicar Filtros
                            </button>
                            <button class="rp-btn rp-btn-success" onclick="exportarExcel()">
                                <i class="bi bi-file-earmark-excel"></i>Exportar Excel
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- KPIs -->
            <div class="row g-3 mb-4 mt-2">
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="stat-label">Total Pedidos</div>
                                <div class="stat-value"><%= estadisticas.total_pedidos %></div>
                            </div>
                            <div class="stat-icon"><i class="bi bi-truck"></i></div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="stat-label">Ingresos</div>
                                <div class="stat-value">$<%= Number(estadisticas.ingresos_totales).toLocaleString('es-CO') %></div>
                                <div class="stat-description">Productos + domicilio + propina</div>
                            </div>
                            <div class="stat-icon"><i class="bi bi-cash-stack"></i></div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="stat-label">Ingresos Domicilio</div>
                                <div class="stat-value">$<%= Number(estadisticas.ingresos_domicilio || 0).toLocaleString('es-CO') %></div>
                                <div class="stat-description">Solo costo de envío</div>
                            </div>
                            <div class="stat-icon"><i class="bi bi-truck"></i></div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="stat-label">Ticket Promedio</div>
                                <div class="stat-value">$<%= Number(estadisticas.ticket_promedio).toLocaleString('es-CO', {maximumFractionDigits:0}) %></div>
                            </div>
                            <div class="stat-icon"><i class="bi bi-graph-up"></i></div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="stat-label">Propinas</div>
                                <div class="stat-value">$<%= Number(estadisticas.propinas_totales).toLocaleString('es-CO') %></div>
                            </div>
                            <div class="stat-icon"><i class="bi bi-cash-coin"></i></div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="stat-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <div class="stat-label">Cancelados</div>
                                <div class="stat-value" style="color: var(--rp-danger);"><%= estadisticas.cancelados || 0 %></div>
                                <div class="stat-description"><%= estadisticas.total_pedidos > 0 ? ((estadisticas.cancelados/estadisticas.total_pedidos)*100).toFixed(1) + '%' : '0%' %> del total</div>
                            </div>
                            <div class="stat-icon"><i class="bi bi-x-circle"></i></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Top Domiciliarios -->
            <div class="table-card">
                <div class="chart-title">
                    <i class="bi bi-person-badge"></i>Top Domiciliarios
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th width="50">#</th>
                                <th>Nombre</th>
                                <th class="text-end">Entregas</th>
                                <th class="text-end">Propinas</th>
                                <th class="text-end">Ticket Prom.</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (topDomiciliarios.length === 0) { %>
                            <tr><td colspan="5">
                                <div class="empty-state">
                                    <i class="bi bi-inbox"></i>
                                    <h5>Sin datos en este período</h5>
                                </div>
                            </td></tr>
                            <% } else { %>
                            <% topDomiciliarios.forEach((d, i) => { %>
                            <tr>
                                <td>
                                    <span class="badge-rank <%= i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : 'other' %>">
                                        <%= i + 1 %>
                                    </span>
                                </td>
                                <td><strong><%= d.nombre %></strong></td>
                                <td class="text-end"><span class="badge bg-primary"><%= d.entregas %></span></td>
                                <td class="text-end">$<%= Number(d.propinas).toLocaleString('es-CO') %></td>
                                <td class="text-end">$<%= Number(d.ticket_promedio).toLocaleString('es-CO', {maximumFractionDigits:0}) %></td>
                            </tr>
                            <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Top Clientes Domicilio -->
            <div class="table-card">
                <div class="chart-title">
                    <i class="bi bi-people"></i>Top Clientes Domicilio
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th width="50">#</th>
                                <th>Nombre</th>
                                <th>Teléfono</th>
                                <th class="text-end">Pedidos</th>
                                <th class="text-end">Monto Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (topClientes.length === 0) { %>
                            <tr><td colspan="5">
                                <div class="empty-state">
                                    <i class="bi bi-inbox"></i>
                                    <h5>Sin datos en este período</h5>
                                </div>
                            </td></tr>
                            <% } else { %>
                            <% topClientes.forEach((c, i) => { %>
                            <tr>
                                <td>
                                    <span class="badge-rank <%= i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : 'other' %>">
                                        <%= i + 1 %>
                                    </span>
                                </td>
                                <td><strong><%= c.nombre %></strong></td>
                                <td><%= c.telefono || '-' %></td>
                                <td class="text-end"><span class="badge bg-primary"><%= c.total_pedidos %></span></td>
                                <td class="text-end"><strong>$<%= Number(c.monto_total).toLocaleString('es-CO') %></strong></td>
                            </tr>
                            <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
    function aplicarFiltros() {
        const desde = document.getElementById('fechaDesde').value;
        const hasta = document.getElementById('fechaHasta').value;
        window.location.href = `/reportes/domicilios?desde=${desde}&hasta=${hasta}`;
    }

    async function exportarExcel() {
        const desde = document.getElementById('fechaDesde').value;
        const hasta = document.getElementById('fechaHasta').value;

        if (!desde || !hasta) {
            window.mostrarToast && mostrarToast({ tipo: 'warning', mensaje: 'Selecciona un rango de fechas' });
            return;
        }

        try {
            const url = `/reportes/exportar?tipo=domicilios&desde=${desde}&hasta=${hasta}`;
            const resp = await fetch(url);
            if (!resp.ok) {
                const data = await resp.json().catch(() => ({}));
                throw new Error(data.error || 'Error al generar el archivo');
            }
            const blob = await resp.blob();
            const downloadUrl = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = downloadUrl;
            a.download = `reporte_domicilios_${desde}_${hasta}.xlsx`;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(downloadUrl);
            document.body.removeChild(a);
            window.mostrarToast && mostrarToast({ tipo: 'success', mensaje: 'Archivo descargado' });
        } catch (e) {
            window.mostrarToast && mostrarToast({ tipo: 'danger', mensaje: e.message || 'Error de conexión' });
        }
    }
    </script>
    </div>
<%- include('../partials/toasts') %>
</body>
</html>
