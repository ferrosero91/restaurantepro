<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reporte de Productos - RestaurantPro</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/static/css/theme.css">
    <link rel="stylesheet" href="/static/css/reportes.css">
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="rp-content">

    <main class="py-2">
        <div class="container-fluid px-3 px-md-4">

            <%- include('../partials/breadcrumbs', { items: [
                { label: 'Reportes', href: '/reportes' },
                { label: 'Top Productos' }
            ] }) %>

            <ul class="nav nav-tabs" role="tablist" aria-label="Secciones de reportes">
                <li class="nav-item" role="presentation">
                    <a class="nav-link" href="/reportes" role="tab">
                        <i class="bi bi-speedometer2" aria-hidden="true"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" href="/reportes#historial" role="tab">
                        <i class="bi bi-receipt" aria-hidden="true"></i>Historial
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link active" href="/reportes/productos" role="tab" aria-selected="true">
                        <i class="bi bi-box-seam" aria-hidden="true"></i>Top Productos
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" href="/reportes/clientes" role="tab">
                        <i class="bi bi-people" aria-hidden="true"></i>Top Clientes
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" href="/reportes/propinas" role="tab">
                        <i class="bi bi-cash-coin" aria-hidden="true"></i>Propinas
                    </a>
                </li>
                <li class="nav-item" role="presentation">
                    <a class="nav-link" href="/reportes/domicilios" role="tab">
                        <i class="bi bi-truck" aria-hidden="true"></i>Domicilios
                    </a>
                </li>
            </ul>

            <div class="table-card">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th width="60">Ranking</th>
                                <th>Código</th>
                                <th>Producto</th>
                                <th class="text-end">Cantidad Vendida</th>
                                <th class="text-end">Veces Vendido</th>
                                <th class="text-end">Total Vendido</th>
                                <th width="200">Participación</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (productos.length === 0) { %>
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-5">
                                        <div class="empty-state">
                                            <i class="bi bi-inbox"></i>
                                            <h5>No hay datos disponibles</h5>
                                            <p>No hay datos de productos en el período seleccionado</p>
                                        </div>
                                    </td>
                                </tr>
                            <% } else { %>
                                <%
                                const totalVentas = productos.reduce((sum, p) => sum + Number(p.total_vendido), 0);
                                productos.forEach((producto, index) => {
                                    const participacion = (Number(producto.total_vendido) / totalVentas * 100).toFixed(1);
                                %>
                                    <tr>
                                        <td>
                                            <span class="badge-rank <%= index === 0 ? 'gold' : index === 1 ? 'silver' : index === 2 ? 'bronze' : 'other' %>">
                                                <%= index + 1 %>
                                            </span>
                                        </td>
                                        <td><code><%= producto.codigo %></code></td>
                                        <td><strong><%= producto.nombre %></strong></td>
                                        <td class="text-end"><%= Number(producto.cantidad_vendida).toFixed(2) %></td>
                                        <td class="text-end"><span class="badge bg-info"><%= producto.veces_vendido %></span></td>
                                        <td class="text-end"><strong>$<%= Number(producto.total_vendido).toLocaleString('es-CO', {minimumFractionDigits:2}) %></strong></td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-grow-1" style="height: 6px; border-radius: 4px;">
                                                    <div class="progress-bar" style="width: <%= participacion %>%; background: var(--rp-gradient-accent);"></div>
                                                </div>
                                                <small class="text-muted" style="min-width: 45px;"><%= participacion %>%</small>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    </div>
<%- include('../partials/toasts') %>
</body>
</html>