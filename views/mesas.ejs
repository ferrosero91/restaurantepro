<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mesas</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/static/css/theme.css">
    <link rel="stylesheet" href="/css/mesas-tactil.css">
    <style>
        html, body { height: 100%; }
        body { min-height: 100vh; display: flex; flex-direction: column; }
        body{background-color:#f8f9fa}
        /* Navbar: estilos gestionados por theme.css + partial/navbar.ejs */
        .mesa-card{border:none;box-shadow:0 .5rem 1rem rgba(0,0,0,.05);transition:transform .1s}
        .mesa-card:hover{transform:translateY(-2px)}
        .estado-badge{position:absolute;top:.75rem;right:.75rem}
    </style>
 </head>
<body>
    <%- include('partials/navbar') %>
    <div class="rp-content">

    <main class="flex-grow-1">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0"><i class="bi bi-grid me-2"></i>Mesas</h4>
            <div>
                <button id="btnGenerarQRTodas" class="btn btn-success me-2"><i class="bi bi-qr-code me-1"></i>Generar QR Todas</button>
                <button id="btnNuevaMesa" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Nueva mesa</button>
            </div>
        </div>

        <div class="row" id="gridMesas">
            <% mesas.forEach(m => { %>
                <div class="col-6 col-md-4 col-lg-3 mb-3">
                    <div
                        class="card mesa-card position-relative"
                        data-mesa-id="<%= m.id %>"
                        data-mesa-numero="<%= m.numero %>"
                        data-mesa-descripcion="<%= m.descripcion || '' %>"
                        data-mesa-estado="<%= m.estado %>"
                        data-mesa-pedidos-abiertos="<%= m.pedidos_abiertos || 0 %>"
                    >
                        <div class="card-body">
                            <span class="badge rounded-pill bg-<%= m.estado === 'libre' ? 'success' : (m.estado === 'ocupada' ? 'warning' : 'secondary') %> estado-badge">
                                <%= m.estado %>
                            </span>
                            <h5 class="card-title mb-1">Mesa <%= m.numero %></h5>
                            <p class="text-muted small mb-3"><%= m.descripcion || '' %></p>
                            <div class="d-grid gap-2">
                                <button class="btn btn-outline-secondary btn-sm btnLiberarMesa">
                                    <i class="bi bi-unlock me-1"></i> Liberar mesa
                                </button>
                                <button class="btn btn-outline-primary btn-sm btnAbrirPedido">
                                    <i class="bi bi-door-open me-1"></i> Abrir / Continuar pedido
                                </button>
                                <button class="btn btn-outline-secondary btn-sm btnVerPedido">
                                    <i class="bi bi-list-ul me-1"></i> Ver pedido
                                </button>
                                <div class="btn-group" role="group" aria-label="Acciones mesa">
                                    <button class="btn btn-outline-dark btn-sm btnEditarMesa">
                                        <i class="bi bi-pencil-square me-1"></i> Editar
                                    </button>
                                    <button class="btn btn-outline-success btn-sm btnGenerarQR">
                                        <i class="bi bi-qr-code me-1"></i> QR
                                    </button>
                                    <button
                                        class="btn btn-outline-danger btn-sm btnEliminarMesa"
                                        <%= (m.pedidos_abiertos || 0) > 0 ? 'disabled' : '' %>
                                        data-bs-toggle="tooltip"
                                        title="<%= (m.pedidos_abiertos || 0) > 0 ? 'No se puede eliminar: tiene pedido activo' : 'Eliminar mesa' %>"
                                    >
                                        <i class="bi bi-trash me-1"></i> Eliminar
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <!-- Modal Pedido (Centrado y Táctil) -->
    <div class="modal fade" id="modalPedido" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-fullscreen">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-cart3 me-2"></i>
                        Pedido Mesa <span id="pedidoMesa"></span>
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="row g-0" style="height: calc(100vh - 120px);">
                        <!-- Panel Izquierdo: Productos -->
                        <div class="col-12 col-md-8 border-end" style="overflow-y: auto;">
                            <div class="p-2 p-md-3">
                                <!-- Buscador -->
                                <div class="mb-2 mb-md-3">
                                    <div class="input-group input-group-lg">
                                        <span class="input-group-text bg-white">
                                            <i class="bi bi-search"></i>
                                        </span>
                                        <input id="buscarProductoMesa" class="form-control" placeholder="Buscar producto..." autocomplete="off">
                                    </div>
                                </div>

                                <!-- Categorías (Pills) -->
                                <div class="mb-2 mb-md-3">
                                    <div class="d-flex gap-2 flex-wrap" id="categoriasFilter">
                                        <button class="btn btn-outline-primary active" data-categoria="">
                                            <i class="bi bi-grid-3x3-gap me-1"></i>
                                            Todos
                                        </button>
                                        <!-- Se cargan dinámicamente -->
                                    </div>
                                </div>

                                <!-- Grid de Productos -->
                                <div id="gridProductos">
                                    <!-- Se cargan dinámicamente -->
                                </div>
                            </div>
                        </div>

                        <!-- Panel Derecho: Carrito -->
                        <div class="col-12 col-md-4 d-flex flex-column bg-light" id="panelCarrito">
                            <div class="p-2 p-md-3 border-bottom bg-white">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h6 class="mb-0">
                                        <i class="bi bi-receipt me-2"></i>
                                        Resumen del Pedido
                                    </h6>
                                    <button class="btn btn-sm btn-close d-md-none" id="btnCerrarCarrito"></button>
                                </div>
                            </div>
                            
                            <div class="flex-grow-1 overflow-auto p-2 p-md-3">
                                <div id="listaItemsPedido">
                                    <div class="text-center text-muted py-5">
                                        <i class="bi bi-cart-x" style="font-size: 3rem;"></i>
                                        <p class="mt-2">No hay productos agregados</p>
                                    </div>
                                </div>
                            </div>

                            <div class="p-2 p-md-3 border-top bg-white">
                                <div class="d-flex justify-content-between align-items-center mb-2 mb-md-3">
                                    <h5 class="mb-0">Total:</h5>
                                    <h4 class="mb-0 text-primary" id="totalPedido">$0</h4>
                                </div>
                                <div class="d-grid gap-2">
                                    <button id="btnEnviarCocina" class="btn btn-warning btn-lg">
                                        <i class="bi bi-send me-2"></i>
                                        Enviar a Cocina
                                    </button>
                                    <button id="btnReenviarCocina" class="btn btn-outline-warning">
                                        <i class="bi bi-arrow-repeat me-2"></i>
                                        Reenviar a Cocina
                                    </button>
                                    <button id="btnFacturarPedido" class="btn btn-success btn-lg">
                                        <i class="bi bi-cash-coin me-2"></i>
                                        Facturar
                                    </button>
                                    <div class="btn-group">
                                        <button id="btnMoverMesa" class="btn btn-outline-secondary">
                                            <i class="bi bi-arrow-left-right me-1"></i>
                                            <span class="d-none d-sm-inline">Mover Mesa</span>
                                            <span class="d-inline d-sm-none">Mover</span>
                                        </button>
                                        <button id="btnLiberarMesaHeader" class="btn btn-outline-danger">
                                            <i class="bi bi-unlock me-1"></i>
                                            Liberar
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Botón flotante para mostrar carrito en móvil -->
                <button class="btn-toggle-carrito" id="btnToggleCarrito">
                    <i class="bi bi-cart3"></i>
                    <span class="badge" id="badgeCarrito">0</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Modal Cantidad (para productos) -->
    <div class="modal fade" id="modalCantidad" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-123 me-2"></i>
                        <span id="nombreProductoCantidad"></span>
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="productoIdCantidad">
                    <input type="hidden" id="productoPrecioCantidad">
                    <input type="hidden" id="productoUnidadCantidad">
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Cantidad</label>
                        <div class="input-group input-group-lg">
                            <button class="btn btn-outline-secondary" type="button" onclick="ajustarCantidad(-1)">
                                <i class="bi bi-dash-lg"></i>
                            </button>
                            <input type="number" class="form-control text-center" id="inputCantidad" value="1" min="0.01" step="0.01">
                            <button class="btn btn-outline-secondary" type="button" onclick="ajustarCantidad(1)">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Nota (opcional)</label>
                        <textarea class="form-control" id="inputNota" rows="2" placeholder="Ej: Sin cebolla, término medio..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" onclick="agregarProductoAlPedido()">
                        <i class="bi bi-cart-plus me-1"></i>
                        Agregar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Pago -->
    <div class="modal fade" id="modalPago" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-cash-coin me-2"></i>Cobrar</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <!-- Cliente -->
                    <div class="mb-3">
                        <label class="form-label fw-bold small"><i class="bi bi-person me-1"></i>Cliente</label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="pagoClienteBuscar" placeholder="Buscar por nombre o cédula..." autocomplete="off">
                            <button class="btn btn-outline-secondary" type="button" id="pagoClienteDefault" title="Consumidor final">
                                <i class="bi bi-person-check"></i>
                            </button>
                        </div>
                        <div id="pagoClienteResultados" class="list-group mt-1" style="max-height:120px;overflow-y:auto;display:none;"></div>
                        <div class="mt-1">
                            <small class="text-muted">Seleccionado: </small>
                            <strong id="pagoClienteNombre" class="text-primary">Consumidor final</strong>
                            <input type="hidden" id="pagoClienteId" value="">
                        </div>
                    </div>

                    <!-- Total -->
                    <div class="text-center mb-3">
                        <div class="small text-muted">Total a cobrar</div>
                        <div class="fs-2 fw-bold text-primary" id="pagoTotal">$0</div>
                    </div>

                    <!-- Propina -->
                    <div id="propinaSeccion" class="mb-3 p-3 border rounded" style="display:none;">
                        <label class="form-label fw-bold small mb-2"><i class="bi bi-heart text-danger me-1"></i>Servicio / Propina</label>
                        <div class="d-flex gap-2 flex-wrap mb-2" id="propinaBotones"></div>
                        <div class="d-flex gap-2 align-items-center">
                            <input type="number" class="form-control form-control-sm" id="propinaCustom" placeholder="Personalizada" min="0" style="max-width:130px;">
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="btnSinPropina">Sin propina</button>
                            <strong class="text-success ms-auto" id="propinaMontoDisplay">$0</strong>
                        </div>
                    </div>

                    <!-- Medio de pago -->
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Medio de pago</label>
                        <select class="form-select" id="pagoMetodo"></select>
                    </div>

                    <!-- Dinero recibido y cambio -->
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label fw-bold small">Dinero recibido</label>
                            <input type="text" id="pagoDineroRecibido" class="form-control form-control-lg" placeholder="0" autocomplete="off">
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold small">Cambio</label>
                            <div id="pagoCambio" class="form-control form-control-lg bg-light fw-bold text-success">$0</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-success btn-lg" id="btnConfirmarPago">
                        <i class="bi bi-check-circle me-1"></i>Confirmar pago
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal QR Code -->
    <div class="modal fade" id="modalQR" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="bi bi-qr-code me-2"></i>Código QR - Mesa <span id="qrMesaNumero"></span></h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center">
                    <div id="qrLoading" class="py-4">
                        <div class="spinner-border text-success" role="status"></div>
                        <p class="mt-2">Generando código QR...</p>
                    </div>
                    <div id="qrContent" style="display:none;">
                        <img id="qrImage" src="" alt="QR Code" class="img-fluid mb-3" style="max-width: 300px;">
                        <p class="text-muted small mb-2">Escanea este código para acceder al menú digital</p>
                        <div class="input-group mb-3">
                            <input type="text" id="qrUrl" class="form-control form-control-sm" readonly>
                            <button class="btn btn-outline-secondary btn-sm" onclick="copiarUrlQR()">
                                <i class="bi bi-clipboard"></i> Copiar
                            </button>
                        </div>
                        <a id="qrDownload" href="#" download="qr-mesa.png" class="btn btn-success">
                            <i class="bi bi-download me-1"></i> Descargar QR
                        </a>
                    </div>
                    <div id="qrError" style="display:none;" class="text-danger py-4">
                        <i class="bi bi-exclamation-triangle" style="font-size: 2rem;"></i>
                        <p class="mt-2" id="qrErrorMsg">Error al generar QR</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    </main>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/vendor/jquery/jquery.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="/js/mesas.js?v=3.0"></script>
    <script>
    // QR Code Generation
    document.addEventListener('DOMContentLoaded', function() {
        // Generar QR para una mesa individual
        document.querySelectorAll('.btnGenerarQR').forEach(btn => {
            btn.addEventListener('click', async function(e) {
                e.stopPropagation();
                const card = this.closest('.mesa-card');
                const mesaId = card.dataset.mesaId;
                const mesaNumero = card.dataset.mesaNumero;
                await generarQR(mesaId, mesaNumero);
            });
        });

        // Generar QR para todas las mesas
        document.getElementById('btnGenerarQRTodas').addEventListener('click', async function() {
            const result = await Swal.fire({
                title: '¿Generar QR para todas las mesas?',
                text: 'Se generarán códigos QR para todas las mesas del restaurante',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Sí, generar',
                cancelButtonText: 'Cancelar'
            });

            if (result.isConfirmed) {
                try {
                    Swal.fire({ title: 'Generando...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                    const response = await fetch('/mesas/qr/bulk', { method: 'POST' });
                    const data = await response.json();
                    Swal.close();

                    if (data.success) {
                        Swal.fire('¡Listo!', `Se generaron ${data.total} códigos QR exitosamente`, 'success');
                    } else {
                        Swal.fire('Error', data.error || 'Error al generar QR', 'error');
                    }
                } catch (error) {
                    Swal.close();
                    Swal.fire('Error', 'Error de conexión al generar QR', 'error');
                }
            }
        });
    });

    async function generarQR(mesaId, mesaNumero) {
        const modal = new bootstrap.Modal(document.getElementById('modalQR'));
        document.getElementById('qrMesaNumero').textContent = mesaNumero;
        document.getElementById('qrLoading').style.display = 'block';
        document.getElementById('qrContent').style.display = 'none';
        document.getElementById('qrError').style.display = 'none';
        modal.show();

        try {
            const response = await fetch(`/mesas/${mesaId}/qr`, { method: 'POST' });
            const data = await response.json();

            document.getElementById('qrLoading').style.display = 'none';

            if (data.success) {
                document.getElementById('qrContent').style.display = 'block';
                document.getElementById('qrImage').src = data.qrImage;
                document.getElementById('qrUrl').value = window.location.origin + data.menuUrl;
                document.getElementById('qrDownload').href = data.qrImage;
                document.getElementById('qrDownload').download = `qr-mesa-${mesaNumero}.png`;
            } else {
                document.getElementById('qrError').style.display = 'block';
                document.getElementById('qrErrorMsg').textContent = data.error || 'Error al generar QR';
            }
        } catch (error) {
            document.getElementById('qrLoading').style.display = 'none';
            document.getElementById('qrError').style.display = 'block';
            document.getElementById('qrErrorMsg').textContent = 'Error de conexión';
        }
    }

    function copiarUrlQR() {
        const input = document.getElementById('qrUrl');
        input.select();
        navigator.clipboard.writeText(input.value).then(() => {
            Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'URL copiada', showConfirmButton: false, timer: 1500 });
        });
    }
    </script>

    <!-- Real-time mesa status updates -->
    <script>
    (function() {
        let mesasSocket = null;

        async function initMesasWebSocket() {
            if (typeof io === 'undefined') {
                // Fallback: polling cada 5 segundos
                setInterval(refreshMesasEstado, 5000);
                return;
            }

            try {
                const resp = await fetch('/api/cocina/ws-token');
                if (!resp.ok) throw new Error('No token');
                const { token } = await resp.json();

                mesasSocket = io({ auth: { token }, transports: ['websocket', 'polling'], reconnection: true, reconnectionDelay: 5000 });

                mesasSocket.on('new_order', function(data) {
                    console.log('[Mesas] Nuevo pedido:', data);
                    refreshMesasEstado();
                    // Notificación visual
                    Swal.fire({ toast: true, position: 'top-end', icon: 'info', title: 'Nuevo pedido - Mesa ' + (data.mesa || 'Domicilio'), showConfirmButton: false, timer: 3000 });
                });

                mesasSocket.on('status_change', function() {
                    refreshMesasEstado();
                });

                mesasSocket.on('order_modified', function() {
                    refreshMesasEstado();
                });

                mesasSocket.on('disconnect', function() {
                    console.log('[Mesas] WebSocket desconectado');
                });

            } catch (e) {
                console.warn('[Mesas] WebSocket no disponible, usando polling');
                setInterval(refreshMesasEstado, 5000);
            }
        }

        async function refreshMesasEstado() {
            try {
                const resp = await fetch('/mesas/listar');
                if (!resp.ok) return;
                const mesas = await resp.json();

                mesas.forEach(function(mesa) {
                    const card = document.querySelector('[data-mesa-id="' + mesa.id + '"]');
                    if (!card) return;

                    const oldEstado = card.dataset.mesaEstado;
                    const newEstado = mesa.estado || 'libre';
                    const pedidosAbiertos = mesa.pedidos_abiertos || 0;

                    if (oldEstado !== newEstado || card.dataset.mesaPedidosAbiertos != pedidosAbiertos) {
                        card.dataset.mesaEstado = newEstado;
                        card.dataset.mesaPedidosAbiertos = pedidosAbiertos;

                        // Actualizar badge de estado
                        const badge = card.querySelector('.estado-badge');
                        if (badge) {
                            badge.className = 'badge rounded-pill estado-badge';
                            if (newEstado === 'libre') badge.classList.add('bg-success');
                            else if (newEstado === 'ocupada') badge.classList.add('bg-warning');
                            else badge.classList.add('bg-secondary');
                            badge.textContent = newEstado;
                        }

                        // Animar la card si cambió de estado
                        if (oldEstado !== newEstado) {
                            card.style.transition = 'box-shadow 0.3s';
                            card.style.boxShadow = '0 0 0 3px rgba(233,69,96,0.5)';
                            setTimeout(function() { card.style.boxShadow = ''; }, 2000);
                        }
                    }
                });
            } catch (e) {
                console.error('[Mesas] Error refreshing:', e);
            }
        }

        // Iniciar WebSocket cuando el DOM esté listo
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initMesasWebSocket);
        } else {
            initMesasWebSocket();
        }
    })();
    </script>
    </div>
<%- include('partials/toasts') %>
</body>
</html>


