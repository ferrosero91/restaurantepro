        function renderizarConfiguracionPropinas() {
            const tipEnabledCheckbox = document.getElementById('tipEnabled');
            const tipConfigSection = document.getElementById('tipConfigSection');
            const container = document.getElementById('tipPercentagesContainer');
            
            if (!tipEnabledCheckbox || !tipConfigSection || !container) return;
            
            // Configurar checkbox
            tipEnabledCheckbox.checked = tipConfigData.enabled;
            tipConfigSection.style.display = tipConfigData.enabled ? 'block' : 'none';
            
            // Renderizar porcentajes
            const percentages = tipConfigData.percentages || [];
            if (percentages.length === 0) {
                // Si no hay porcentajes, mostrar campos vacíos por defecto
                container.innerHTML = `
                    <div class="row g-2 mb-2">
                        <div class="col-md-3">
                            <div class="input-group">
