                                <span class="input-group-text">%</span>
                                <button type="button" class="btn btn-outline-danger btn-remove-percentage" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="input-group">
                                <input type="number" class="form-control tip-percentage" min="0" max="100" step="1" placeholder="20">
                                <span class="input-group-text">%</span>
                                <button type="button" class="btn btn-outline-danger btn-remove-percentage" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            } else {
                // Renderizar porcentajes existentes
                const rows = [];
                for (let i = 0; i < percentages.length; i += 3) {
                    const rowPercentages = percentages.slice(i, i + 3);
                    const rowHtml = `
                        <div class="row g-2 mb-2">
                            ${rowPercentages.map(percentage => `
                                <div class="col-md-3">
                                    <div class="input-group">
                                        <input type="number" class="form-control tip-percentage" min="0" max="100" step="1" value="${percentage}">
                                        <span class="input-group-text">%</span>
                                        <button type="button" class="btn btn-outline-danger btn-remove-percentage" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            `).join('')}
                        </div>
                    `;
                    rows.push(rowHtml);
                }
                container.innerHTML = rows.join('');
            }
            
            // Agregar event listeners
            agregarEventListenersPropinas();
        }
        
        function agregarEventListenersPropinas() {
            // Toggle de activación
            const tipEnabledCheckbox = document.getElementById('tipEnabled');
            const tipConfigSection = document.getElementById('tipConfigSection');
            
            if (tipEnabledCheckbox && tipConfigSection) {
                tipEnabledCheckbox.addEventListener('change', function() {
                    tipConfigSection.style.display = this.checked ? 'block' : 'none';
                });
            }
            
            // Botón agregar porcentaje
            const btnAddPercentage = document.getElementById('btnAddPercentage');
            if (btnAddPercentage) {
                btnAddPercentage.addEventListener('click', function() {
                    const container = document.getElementById('tipPercentagesContainer');
                    if (!container) return;
                    
                    // Buscar la última fila o crear una nueva
                    let lastRow = container.querySelector('.row:last-child');
                    let inputsInLastRow = lastRow ? lastRow.querySelectorAll('.tip-percentage').length : 3;
                    
                    if (inputsInLastRow >= 3) {
                        // Crear nueva fila
                        const newRow = document.createElement('div');
                        newRow.className = 'row g-2 mb-2';
                        newRow.innerHTML = `
                            <div class="col-md-3">
                                <div class="input-group">
                                    <input type="number" class="form-control tip-percentage" min="0" max="100" step="1" placeholder="25">
                                    <span class="input-group-text">%</span>
                                    <button type="button" class="btn btn-outline-danger btn-remove-percentage" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        `;
                        container.appendChild(newRow);
                    } else {
                        // Agregar a la fila existente
                        const newCol = document.createElement('div');
                        newCol.className = 'col-md-3';
                        newCol.innerHTML = `
                            <div class="input-group">
                                <input type="number" class="form-control tip-percentage" min="0" max="100" step="1" placeholder="25">
                                <span class="input-group-text">%</span>
                                <button type="button" class="btn btn-outline-danger btn-remove-percentage" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        `;
                        lastRow.appendChild(newCol);
                    }
                    
                    // Re-agregar event listeners
                    agregarEventListenersEliminar();
                });
            }
            
            // Event listeners para eliminar
            agregarEventListenersEliminar();
            
            // Botón guardar
            const btnGuardar = document.getElementById('btnGuardarPropinas');
            if (btnGuardar) {
                btnGuardar.addEventListener('click', guardarConfiguracionPropinas);
            }
            
            // Botón cancelar
            const btnCancelar = document.getElementById('btnCancelarPropinas');
            if (btnCancelar) {
                btnCancelar.addEventListener('click', function() {
                    renderizarConfiguracionPropinas(); // Restaurar valores originales
                });
            }
        }
        
        function agregarEventListenersEliminar() {
            const removeButtons = document.querySelectorAll('.btn-remove-percentage');
            removeButtons.forEach(button => {
                button.addEventListener('click', function() {
                    const col = this.closest('.col-md-3');
                    const row = col.parentElement;
                    
                    // Eliminar la columna
                    col.remove();
                    
                    // Si la fila queda vacía, eliminarla
                    if (row.children.length === 0) {
                        row.remove();
                    }
                });
            });
        }
        
        async function guardarConfiguracionPropinas() {
            try {
                const tipEnabled = document.getElementById('tipEnabled').checked;
                const percentageInputs = document.querySelectorAll('.tip-percentage');
                
                // Recopilar porcentajes válidos
                const percentages = [];
                percentageInputs.forEach(input => {
                    const value = parseFloat(input.value);
                    if (!isNaN(value) && value >= 0 && value <= 100) {
                        percentages.push(value);
                    }
                });
                
                // Validar que haya al menos un porcentaje si está activado
                if (tipEnabled && percentages.length === 0) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Configuración incompleta',
                        text: 'Debes configurar al menos un porcentaje de propina o desactivar el sistema de propinas.'
                    });
                    return;
                }
                
                const configData = {
                    enabled: tipEnabled,
                    percentages: percentages
                };
                
                // Mostrar loading
                Swal.fire({
                    title: 'Guardando configuración...',
                    html: 'Por favor espera',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });
                
                const response = await fetch('/configuracion/propinas', {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(configData)
                });
                
                if (response.ok) {
                    tipConfigData = configData;
                    Swal.fire({
                        icon: 'success',
                        title: '¡Configuración guardada!',
                        text: 'La configuración de propinas se ha actualizado correctamente.',
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    const errorData = await response.json();
                    Swal.fire({
                        icon: 'error',
                        title: 'Error al guardar',
                        text: errorData.error || 'No se pudo guardar la configuración de propinas.'
                    });
                }
            } catch (error) {
                console.error('Error al guardar configuración de propinas:', error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Error al guardar la configuración de propinas.'
                });
            }
        }
        
