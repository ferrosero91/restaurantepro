<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configuración - RestaurantPro</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/static/css/theme.css">
    <style>
        html, body { height: 100%; }
        body { 
            min-height: 100vh; 
            display: flex; 
            flex-direction: column;
            background-color: #f8f9fa;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }
        
        .page-header {
            background: white;
            border-radius: 8px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.05);
        }
        
        .page-header h2 {
            font-size: 1.5rem;
            margin-bottom: 0.25rem;
        }
        
        .nav-tabs {
            border-bottom: 2px solid #dee2e6;
            flex-wrap: nowrap;
            overflow-x: auto;
            overflow-y: hidden;
            -webkit-overflow-scrolling: touch;
        }
        
        .nav-tabs::-webkit-scrollbar {
            height: 4px;
        }
        
        .nav-tabs::-webkit-scrollbar-thumb {
            background: #3498db;
            border-radius: 4px;
        }
        
        .nav-tabs .nav-link {
            color: #6c757d;
            border: none;
            padding: 0.875rem 1.25rem;
            font-weight: 500;
            transition: all 0.2s;
            white-space: nowrap;
            font-size: 0.9rem;
        }
        
        .nav-tabs .nav-link:hover {
            color: #3498db;
            border: none;
        }
        
        .nav-tabs .nav-link.active {
            color: #3498db;
            background: transparent;
            border: none;
            border-bottom: 3px solid #3498db;
        }
        
        .nav-tabs .nav-link i {
            font-size: 1rem;
        }
        
        .tab-content {
            background: white;
            border-radius: 8px;
            padding: 1.5rem;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.05);
        }
        
        .section-title {
            color: #667eea;
            font-weight: 600;
            font-size: 1rem;
            margin-bottom: 1.25rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #e9ecef;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .form-label {
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 0.5rem;
            font-size: 0.875rem;
        }
        
        .form-control, .form-select {
            border-radius: 4px;
            border: 1px solid #dee2e6;
            padding: 0.625rem 0.875rem;
            font-size: 0.9rem;
        }
        
        .form-control:focus, .form-select:focus {
            border-color: #3498db;
            box-shadow: 0 0 0 0.2rem rgba(52, 152, 219, 0.15);
        }
        
        .btn-primary {
            background-color: #3498db;
            border-color: #3498db;
            padding: 0.625rem 1.5rem;
            font-weight: 500;
        }
        
        .btn-primary:hover {
            background-color: #2980b9;
            border-color: #2980b9;
        }
        
        .user-avatar, .client-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 1.1rem;
        }
        
        .badge-rol {
            padding: 0.5rem 0.875rem;
            font-weight: 500;
            border-radius: 20px;
        }
        
        .table thead th {
            background: #f8f9fa;
            border-bottom: 2px solid #dee2e6;
            color: #2c3e50;
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            padding: 0.875rem 0.75rem;
        }
        
        .table tbody tr:hover {
            background: #f8f9fa;
        }
        
        .table tbody td {
            padding: 0.875rem 0.75rem;
            vertical-align: middle;
        }
        
        .permission-card {
            border: 2px solid #e9ecef;
            border-radius: 8px;
            padding: 0.875rem;
            transition: all 0.2s;
            cursor: pointer;
            height: 100%;
            background: white;
        }
        
        .permission-card:hover {
            border-color: #3498db;
            background: #f8f9fa;
            transform: translateY(-2px);
        }
        
        .permission-card.selected {
            border-color: #3498db;
            background: #e3f2fd;
        }
        
        .permission-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
        }
        
        .permission-icon.purple { background: rgba(102, 126, 234, 0.1); color: #667eea; }
        .permission-icon.blue { background: rgba(52, 152, 219, 0.1); color: #3498db; }
        .permission-icon.green { background: rgba(46, 204, 113, 0.1); color: #2ecc71; }
        .permission-icon.orange { background: rgba(243, 156, 18, 0.1); color: #f39c12; }
        
        .permission-title {
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 0.125rem;
            font-size: 0.875rem;
        }
        
        .permission-desc {
            font-size: 0.75rem;
            color: #6c757d;
            line-height: 1.3;
        }
        
        .admin-checkbox {
            padding: 1rem;
            background: #f8f9fa;
            border-radius: 8px;
            border: 2px solid #dee2e6;
        }
        
        .admin-checkbox.checked {
            background: #e3f2fd;
            border-color: #3498db;
        }
        
        .modal-header {
            background: #f8f9fa;
            border-bottom: 2px solid #e9ecef;
        }
        
        .modal-title {
            color: #2c3e50;
            font-weight: 600;
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .page-header {
                padding: 1rem;
            }
            
            .page-header h2 {
                font-size: 1.25rem;
            }
            
            .page-header p {
                font-size: 0.875rem;
            }
            
            .nav-tabs .nav-link {
                padding: 0.75rem 1rem;
                font-size: 0.85rem;
            }
            
            .nav-tabs .nav-link i {
                font-size: 0.9rem;
            }
            
            .tab-content {
                padding: 1rem;
            }
            
            .section-title {
                font-size: 0.9rem;
            }
            
            .table {
                font-size: 0.85rem;
            }
            
            .table thead th {
                padding: 0.625rem 0.5rem;
                font-size: 0.75rem;
            }
            
            .table tbody td {
                padding: 0.625rem 0.5rem;
            }
            
            .user-avatar, .client-avatar {
                width: 32px;
                height: 32px;
                font-size: 0.9rem;
            }
            
            .btn-sm {
                padding: 0.25rem 0.5rem;
                font-size: 0.8rem;
            }
            
            .permission-card {
                padding: 0.75rem;
            }
            
            .permission-icon {
                width: 32px;
                height: 32px;
                font-size: 1rem;
            }
            
            .permission-title {
                font-size: 0.8rem;
            }
            
            .permission-desc {
                font-size: 0.7rem;
            }
            
            .modal-dialog {
                margin: 0.5rem;
            }
            
            .modal-body {
                padding: 1rem;
            }
        }
        
        @media (max-width: 576px) {
            .table-responsive {
                font-size: 0.8rem;
            }
            
            .d-flex.gap-2 {
                flex-direction: column;
            }
            
            .d-flex.gap-2 .btn {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="rp-content">
    <main class="flex-grow-1">
    <div class="container-fluid px-3 px-md-4 py-3">
        
        <!-- Tabs de navegación -->
        <ul class="nav nav-tabs mb-0" id="configTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="negocio-tab" data-bs-toggle="tab" data-bs-target="#negocio" type="button">
                    <i class="bi bi-shop me-2"></i>Negocio
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="impresion-tab" data-bs-toggle="tab" data-bs-target="#impresion" type="button">
                    <i class="bi bi-printer me-2"></i>Impresión
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="medios-pago-tab" data-bs-toggle="tab" data-bs-target="#medios-pago" type="button">
                    <i class="bi bi-credit-card me-2"></i>Medios de Pago
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="categorias-tab" data-bs-toggle="tab" data-bs-target="#categorias" type="button">
                    <i class="bi bi-tags me-2"></i>Categorías
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="clientes-tab" data-bs-toggle="tab" data-bs-target="#clientes" type="button">
                    <i class="bi bi-people me-2"></i>Clientes
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="propinas-tab" data-bs-toggle="tab" data-bs-target="#propinas" type="button">
                    <i class="bi bi-cash-coin me-2"></i>Propinas
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="usuarios-tab" data-bs-toggle="tab" data-bs-target="#usuarios" type="button">
                    <i class="bi bi-person-badge me-2"></i>Usuarios
                </button>
            </li>
        </ul>
        
        <!-- Contenido de las tabs -->
        <div class="tab-content" id="configTabContent">
        
        <!-- Contenido de las tabs -->
        <div class="tab-content" id="configTabContent">
            
            <!-- TAB: Datos del Negocio -->
            <div class="tab-pane fade show active" id="negocio" role="tabpanel">
                <form action="/configuracion" method="POST" enctype="multipart/form-data">
                    <div class="section-title">
                        <i class="bi bi-building me-2"></i>Información del Negocio
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label">Nombre del Negocio <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="nombre_negocio" value="<%= config.nombre_negocio || '' %>" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">NIT/RUT</label>
                            <input type="text" class="form-control" name="nit" value="<%= config.nit || '' %>">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Dirección</label>
                            <input type="text" class="form-control" name="direccion" value="<%= config.direccion || '' %>">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Teléfono</label>
                            <input type="text" class="form-control" name="telefono" value="<%= config.telefono || '' %>">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">WhatsApp <span class="badge bg-success">Tienda</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-whatsapp"></i></span>
                                <input type="text" class="form-control" name="whatsapp" value="<%= config.whatsapp || '' %>" placeholder="573001234567">
                            </div>
                            <small class="text-muted">Número con código de país (ej: 573001234567). Se muestra en la tienda online.</small>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Slogan <span class="badge bg-info">Tienda</span></label>
                            <input type="text" class="form-control" name="slogan" value="<%= config.slogan || '' %>" placeholder="Los mejores sabores de la ciudad" maxlength="255">
                            <small class="text-muted">Se muestra en la tienda online debajo del nombre.</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Valor Domicilio <span class="badge bg-warning text-dark">Delivery</span></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control" id="inputCostoDomicilio" value="0" min="0" placeholder="5000">
                            </div>
                            <small class="text-muted">Costo de envío que se cobra al cliente en pedidos a domicilio.</small>
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <button type="button" class="btn btn-outline-warning btn-sm" id="btnGuardarDomicilio">
                                <i class="bi bi-truck me-1"></i>Guardar Valor Domicilio
                            </button>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">URL Tienda Online <span class="badge bg-info">Público</span></label>
                            <div class="input-group">
                                <span class="input-group-text">/tienda/</span>
                                <input type="text" class="form-control" id="inputSlug" value="<%= typeof restauranteSlug !== 'undefined' ? restauranteSlug : '' %>" placeholder="mi-restaurante">
                            </div>
                            <small class="text-muted">URL pública para pedidos online. Solo letras, números y guiones.</small>
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <button type="button" class="btn btn-outline-primary btn-sm" id="btnGuardarSlug">
                                <i class="bi bi-link-45deg me-1"></i>Guardar URL
                            </button>
                            <% if (typeof restauranteSlug !== 'undefined' && restauranteSlug) { %>
                            <a href="/tienda/<%= restauranteSlug %>" target="_blank" class="btn btn-outline-success btn-sm ms-2">
                                <i class="bi bi-box-arrow-up-right me-1"></i>Ver Tienda
                            </a>
                            <% } %>
                        </div>
                    </div>
                    
                    <div class="section-title">
                        <i class="bi bi-image me-2"></i>Imágenes
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label">Logo del Negocio</label>
                            <input id="inputLogo" type="file" class="form-control" name="logo" accept="image/*">
                            <div class="mt-2">
                                <% if (config.logo_src) { %>
                                    <div class="small text-success mb-1">
                                        <i class="bi bi-check-circle me-1"></i>Logo guardado actualmente
                                    </div>
                                <% } else { %>
                                    <div class="small text-muted mb-1">
                                        <i class="bi bi-info-circle me-1"></i>No hay logo guardado
                                    </div>
                                <% } %>
                                <img id="previewLogo" src="<%= config.logo_src || '' %>" alt="Logo" 
                                     class="border rounded p-1 bg-white" 
                                     style="max-width: 200px; display: <%= config.logo_src ? 'block' : 'none' %>;">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">QR para Transferencias</label>
                            <input id="inputQr" type="file" class="form-control" name="qr" accept="image/*">
                            <div class="mt-2">
                                <% if (config.qr_src) { %>
                                    <div class="small text-success mb-1">
                                        <i class="bi bi-check-circle me-1"></i>QR guardado actualmente
                                    </div>
                                <% } else { %>
                                    <div class="small text-muted mb-1">
                                        <i class="bi bi-info-circle me-1"></i>No hay QR guardado
                                    </div>
                                <% } %>
                                <img id="previewQr" src="<%= config.qr_src || '' %>" alt="QR" 
                                     class="border rounded p-1 bg-white" 
                                     style="max-width: 150px; display: <%= config.qr_src ? 'block' : 'none' %>;">
                            </div>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Pie de Página</label>
                            <textarea class="form-control" name="pie_pagina" rows="3"><%= config.pie_pagina || '' %></textarea>
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-2"></i>Guardar Cambios
                        </button>
                        <a href="/" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
            
            <!-- TAB: Impresión -->
            <div class="tab-pane fade" id="impresion" role="tabpanel">
                <form action="/configuracion" method="POST">
                    <div class="section-title">
                        <i class="bi bi-printer-fill me-2"></i>Configuración de Impresión
                    </div>
                    <div class="alert alert-info small mb-3">
                        <i class="bi bi-info-circle me-2"></i>
                        Selecciona las impresoras instaladas en este equipo para comandas y facturas. La impresión se realizará directamente sin mostrar diálogo.
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Impresora de Cocina (Comandas)</label>
                            <select class="form-control" name="printer_name" id="selectPrinterCocina">
                                <option value="">Cargando impresoras...</option>
                            </select>
                            <small class="text-muted">Se usará para imprimir comandas automáticamente</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Impresora de Caja (Facturas)</label>
                            <select class="form-control" name="printer_ip" id="selectPrinterCaja">
                                <option value="">Cargando impresoras...</option>
                            </select>
                            <small class="text-muted">Se usará para imprimir facturas</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Ancho de Papel</label>
                            <select class="form-control" name="ancho_papel">
                                <option value="58" <%= config.ancho_papel == 58 ? 'selected' : '' %>>58mm (Impresora pequeña)</option>
                                <option value="80" <%= (config.ancho_papel || 80) == 80 ? 'selected' : '' %>>80mm (Impresora estándar)</option>
                            </select>
                            <small class="text-muted">Ancho del papel de las impresoras térmicas</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Impresión automática de comandas</label>
                            <select class="form-control" name="printer_type">
                                <option value="thermal" <%= (config.printer_type || 'thermal') === 'thermal' ? 'selected' : '' %>>Activada</option>
                                <option value="standard" <%= config.printer_type === 'standard' ? 'selected' : '' %>>Desactivada</option>
                            </select>
                            <small class="text-muted">Cuando llega un pedido a cocina, se imprime automáticamente</small>
                        </div>
                    </div>
                    <!-- Campos ocultos para mantener compatibilidad -->
                    <input type="hidden" name="printer_port" value="<%= config.printer_port || '' %>">
                    <input type="hidden" name="font_size" value="<%= config.font_size || 1 %>">
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-2"></i>Guardar Cambios
                        </button>
                        <button type="button" class="btn btn-success" id="btnProbarImpresora">
                            <i class="bi bi-printer-fill me-2"></i>Probar Impresión
                        </button>
                        <a href="/" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
            
            <!-- TAB: Medios de Pago -->
            <div class="tab-pane fade" id="medios-pago" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                    <div class="section-title mb-0">
                        <i class="bi bi-credit-card me-2"></i>Medios de Pago
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-warning btn-sm" id="btnMigrarProductos" title="Permitir eliminar productos">
                            <i class="bi bi-tools me-1"></i>Migración DB
                        </button>
                        <button type="button" class="btn btn-primary btn-sm" id="btnNuevoMedioPago">
                            <i class="bi bi-plus-circle me-1"></i>Nuevo Medio de Pago
                        </button>
                    </div>
                </div>
                
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    Configura los medios de pago disponibles en tu restaurante. Estos aparecerán como opciones al generar facturas.
                </div>
                
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 50px;">Orden</th>
                                <th>Nombre</th>
                                <th>Código</th>
                                <th>Descripción</th>
                                <th style="width: 100px;">Estado</th>
                                <th style="width: 120px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="tablaMediosPago">
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="bi bi-hourglass-split me-2"></i>Cargando medios de pago...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            
            <!-- TAB: Categorías -->
            <div class="tab-pane fade" id="categorias" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                    <div class="section-title mb-0">
                        <i class="bi bi-tags me-2"></i>Categorías de Productos
                    </div>
                    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modalNuevaCategoria">
                        <i class="bi bi-plus-circle me-2"></i>Nueva Categoría
                    </button>
                </div>
                <div id="listaCategorias" class="row g-3">
                    <!-- Se carga dinámicamente -->
                </div>
            </div>
            
            <!-- TAB: Clientes -->
            <div class="tab-pane fade" id="clientes" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                    <div class="section-title mb-0">
                        <i class="bi bi-people me-2"></i>Gestión de Clientes
                    </div>
                    <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modalNuevoCliente">
                        <i class="bi bi-plus-circle me-2"></i>Nuevo Cliente
                    </button>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle" id="tablaClientes">
                        <thead>
                            <tr>
                                <th>Cliente</th>
                                <th>Documento</th>
                                <th>Email</th>
                                <th>Teléfono</th>
                                <th>Ciudad</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Se carga dinámicamente -->
                        </tbody>
                    </table>
                </div>
            </div>
            
            
            <!-- TAB: Propinas -->
            <div class="tab-pane fade" id="propinas" role="tabpanel">
