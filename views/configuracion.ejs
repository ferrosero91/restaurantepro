        function renderizarPermisos(containerId, permisosSeleccionados = []) {
            const container = document.getElementById(containerId);
            const colors = ['purple', 'blue', 'green', 'orange'];
            
            container.innerHTML = permisosData.map((permiso, index) => {
                const isSelected = permisosSeleccionados.includes(permiso.id);
                const color = colors[index % colors.length];
                
                return `
                    <div class="col-md-6">
                        <div class="permission-card ${isSelected ? 'selected' : ''}" data-permiso-id="${permiso.id}">
                            <input type="checkbox" class="form-check-input d-none" name="permisos[]" value="${permiso.id}" ${isSelected ? 'checked' : ''}>
                            <div class="d-flex align-items-start gap-2">
                                <div class="permission-icon ${color}">
                                    <i class="${permiso.icono}"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="permission-title">${permiso.nombre}</div>
                                    <div class="permission-desc">${permiso.descripcion}</div>
                                </div>
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" ${isSelected ? 'checked' : ''}>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
            
            // Agregar event listeners
            container.querySelectorAll('.permission-card').forEach(card => {
                card.addEventListener('click', function(e) {
                    if (e.target.type !== 'checkbox') {
                        const checkbox = this.querySelector('input[name="permisos[]"]');
                        const visibleCheckbox = this.querySelector('.form-check-input:not([name])');
                        checkbox.checked = !checkbox.checked;
                        visibleCheckbox.checked = checkbox.checked;
                        this.classList.toggle('selected', checkbox.checked);
                    }
                });
                
                const visibleCheckbox = card.querySelector('.form-check-input:not([name])');
                visibleCheckbox.addEventListener('change', function() {
                    const checkbox = card.querySelector('input[name="permisos[]"]');
                    checkbox.checked = this.checked;
                    card.classList.toggle('selected', this.checked);
                });
            });
        }
        
