        // Cargar impresoras de Windows en los selects
        async function cargarImpresoras() {
            try {
                const resp = await fetch('/configuracion/printers');
                const data = await resp.json();
                const printers = data.printers || [];
                
                const selectCocina = document.getElementById('selectPrinterCocina');
                const selectCaja = document.getElementById('selectPrinterCaja');
                
                const currentCocina = '<%= config.printer_name || "" %>';
                const currentCaja = '<%= config.printer_ip || "" %>';
                
                const buildOptions = (select, currentValue) => {
                    select.innerHTML = '<option value="">(Ninguna - usar diálogo de Windows)</option>';
                    printers.forEach(p => {
                        const name = p.name || p.deviceId || p;
                        const opt = document.createElement('option');
                        opt.value = name;
                        opt.textContent = name;
                        if (name === currentValue) opt.selected = true;
                        select.appendChild(opt);
                    });
                };
                
                if (printers.length > 0) {
                    buildOptions(selectCocina, currentCocina);
                    buildOptions(selectCaja, currentCaja);
                } else {
                    selectCocina.innerHTML = '<option value="">No se detectaron impresoras</option>';
                    selectCaja.innerHTML = '<option value="">No se detectaron impresoras</option>';
                    if (data.error) {
                        console.warn('Error cargando impresoras:', data.error);
                    }
                }
            } catch(e) {
                console.error('Error cargando impresoras:', e);
                document.getElementById('selectPrinterCocina').innerHTML = '<option value="">Error al cargar</option>';
                document.getElementById('selectPrinterCaja').innerHTML = '<option value="">Error al cargar</option>';
            }
        }
        cargarImpresoras();

