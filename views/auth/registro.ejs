<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro - RestaurantPro</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/static/css/theme.css">
    <style>
        body {
            background: var(--rp-slate-100);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
        }
        .registro-container { width: 100%; max-width: 650px; margin: 0 auto; padding: 1.5rem; flex: 1; display: flex; align-items: center; justify-content: center; }
        .registro-container { width: 100%; max-width: 650px; margin: 0 auto; }
        .registro-card {
            background: #fff;
            border-radius: var(--rp-radius-xl);
            box-shadow: var(--rp-shadow-lg);
            overflow: hidden;
        }
        .registro-header {
            background: var(--rp-gradient-slate);
            color: #fff;
            padding: 2.5rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .registro-header::before {
            content: '';
            position: absolute;
            top: -40%; right: -40%;
            width: 90%; height: 90%;
            background: radial-gradient(circle, rgba(233,69,96,0.18) 0%, transparent 70%);
            border-radius: 50%;
        }
        .registro-header i { font-size: 3.5rem; margin-bottom: 0.5rem; position: relative; }
        .registro-header h3 { font-size: 1.8rem; font-weight: 700; margin: 0.5rem 0 0.25rem; position: relative; }
        .registro-header p { font-size: 0.95rem; opacity: 0.85; margin: 0; position: relative; }
        .registro-body { padding: 2rem; }

        .section-title {
            border-bottom: 2px solid var(--rp-accent);
            padding-bottom: 0.5rem;
            margin-bottom: 1.5rem;
            color: var(--rp-text-strong);
            font-weight: 700;
            font-size: 1.1rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }
        .text-link { color: var(--rp-accent); font-weight: 600; }
        .text-link:hover { color: var(--rp-accent-hover); text-decoration: underline; }
    </style>
</head>
<body>
    <div class="registro-container">
        <div class="registro-card">
            <div class="registro-header">
                <i class="bi bi-shop"></i>
                <h3>Crear Cuenta</h3>
                <p>Registra tu restaurante en RestaurantPro</p>
            </div>
            <div class="registro-body">
                <% if (error) { %>
                <div class="rp-alert rp-alert-error" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <%= error %>
                </div>
                <% } %>
                <% if (success) { %>
                <div class="rp-alert rp-alert-success" role="alert">
                    <i class="bi bi-check-circle-fill"></i>
                    <%= success %>
                </div>
                <% } %>

                <form method="POST" action="/registro">
                    <div class="section-title"><i class="bi bi-building"></i> Datos del Restaurante</div>

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label class="rp-label">Nombre del Restaurante *</label>
                            <input type="text" name="restaurante_nombre" class="rp-input" placeholder="Mi Restaurante" required>
                        </div>
                        <div class="col-md-6">
                            <label class="rp-label">Slug (URL única) *</label>
                            <input type="text" name="restaurante_slug" class="rp-input" placeholder="mi-restaurante" pattern="[a-z0-9-]+" required>
                            <small class="text-muted">Solo letras minúsculas, números y guiones</small>
                        </div>
                    </div>

                    <div class="section-title mt-4"><i class="bi bi-person-circle"></i> Datos del Administrador</div>

                    <div class="mb-3">
                        <label class="rp-label">Nombre Completo *</label>
                        <input type="text" name="nombre" class="rp-input" placeholder="Juan Pérez" required>
                    </div>

                    <div class="mb-3">
                        <label class="rp-label">Correo Electrónico *</label>
                        <input type="email" name="email" class="rp-input" placeholder="tu@email.com" required>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label class="rp-label">Contraseña *</label>
                            <input type="password" name="password" class="rp-input" placeholder="••••••••" minlength="6" required>
                            <small class="text-muted">Mínimo 6 caracteres</small>
                        </div>
                        <div class="col-md-6">
                            <label class="rp-label">Confirmar Contraseña *</label>
                            <input type="password" name="password_confirm" class="rp-input" placeholder="••••••••" minlength="6" required>
                        </div>
                    </div>

                    <button type="submit" class="rp-btn rp-btn-primary w-100 mb-3">
                        <i class="bi bi-check-circle"></i> Crear Cuenta
                    </button>

                    <div class="text-center">
                        <small class="rp-text-muted">
                            ¿Ya tienes cuenta?
                            <a href="/login" class="text-link">Inicia sesión aquí</a>
                        </small>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <footer class="rp-footer">
        <div class="container-fluid">
            <div class="rp-footer-inner">
                <span class="rp-footer-brand">
                    <i class="bi bi-shop"></i> RestaurantPro
                </span>
                <span class="rp-footer-copy">
                    &copy; <%= new Date().getFullYear() %>
                    <strong>GestionXpress</strong> &middot; Todos los derechos reservados
                </span>
            </div>
        </div>
    </footer>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>