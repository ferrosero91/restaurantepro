<%
const hasPermission = (typeof locals.hasPermission === 'function')
    ? locals.hasPermission
    : ((ruta) => {
        if (!user) return false;
        if (user.rol === 'superadmin') return true;
        return user.permisosRutas && user.permisosRutas.includes(ruta);
    });

const navItems = [
    { href: '/', icon: 'bi-house-fill', label: 'Inicio', perm: '/' },
    { href: '/mesas', icon: 'bi-grid', label: 'Mesas', perm: '/mesas' },
    { href: '/cocina', icon: 'bi-egg-fried', label: 'Cocina', perm: '/cocina' },
    { href: '/reportes', icon: 'bi-bar-chart-line', label: 'Reportes', perm: '/reportes' },
    { href: '/productos', icon: 'bi-box', label: 'Productos', perm: '/productos' },
    { href: '/domicilios', icon: 'bi-truck', label: 'Domicilios', perm: '/domicilios' },
    { href: '/clientes', icon: 'bi-people', label: 'Clientes', perm: '/clientes' },
    { href: '/configuracion', icon: 'bi-gear', label: 'Config', perm: '/configuracion' },
];

const currentPath = (typeof locals.currentPath !== 'undefined') ? locals.currentPath : '';
const visibleItems = navItems.filter(item => hasPermission(item.perm));
%>

<!-- Toggle botón — solo móvil -->
<button class="rp-sidebar-toggle" id="sidebarToggle"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
        aria-controls="sidebar">
    <i class="bi bi-list" aria-hidden="true"></i>
</button>

<!-- Backdrop — solo móvil -->
<div class="rp-sidebar-backdrop" id="sidebarBackdrop" aria-hidden="true"></div>

<!-- Sidebar -->
<aside class="rp-sidebar" id="sidebar"
       role="navigation"
       aria-label="Navegación principal">

    <a class="rp-sidebar-brand" href="/" aria-label="RestaurantPro - Inicio">
        <i class="bi bi-shop" aria-hidden="true"></i>
        <span>RestaurantPro</span>
    </a>

    <ul class="rp-sidebar-nav" role="list">
        <% visibleItems.forEach((item, idx) => { %>
        <li class="rp-sidebar-item" role="listitem">
            <a href="<%= item.href %>"
               class="rp-sidebar-link<%= currentPath === item.href ? ' is-active' : '' %>"
               data-page="<%= item.href %>"
               <% if (currentPath === item.href) { %>aria-current="page"<% } %>>
                <i class="bi <%= item.icon %>" aria-hidden="true"></i>
                <span><%= item.label %></span>
            </a>
        </li>
        <% }); %>
    </ul>

    <div class="rp-sidebar-footer">
        <div class="rp-sidebar-user" id="sidebarUserToggle"
             role="button"
             tabindex="0"
             aria-expanded="false"
             aria-controls="sidebarUserMenu"
             aria-label="<%= (user && user.nombre) ? user.nombre : 'Usuario' %> - Menú de cuenta">
            <div class="rp-user-avatar" aria-hidden="true">
                <i class="bi bi-person"></i>
            </div>
            <div class="rp-user-info">
                <div class="rp-user-name"><%= (user && user.nombre) ? user.nombre : 'Usuario' %></div>
                <div class="rp-user-role"><%= (user && user.rol) ? user.rol : '' %></div>
            </div>
            <i class="bi bi-chevron-up rp-user-chevron" aria-hidden="true" style="font-size:0.7rem; opacity:0.5;"></i>
        </div>
        <ul class="rp-sidebar-user-menu" id="sidebarUserMenu" role="menu" aria-label="Opciones de cuenta">
            <li role="none">
                <a href="/logout" role="menuitem">
                    <i class="bi bi-box-arrow-right" aria-hidden="true"></i> Cerrar Sesión
                </a>
            </li>
        </ul>
    </div>
</aside>

<script>
(function() {
    const sidebar   = document.getElementById('sidebar');
    const toggle    = document.getElementById('sidebarToggle');
    const backdrop  = document.getElementById('sidebarBackdrop');
    const userBtn   = document.getElementById('sidebarUserToggle');
    const userMenu  = document.getElementById('sidebarUserMenu');

    // Toggle del sidebar en móvil
    if (toggle && sidebar) {
        toggle.addEventListener('click', () => {
            const isOpen = sidebar.classList.toggle('is-open');
            backdrop.classList.toggle('is-visible', isOpen);
            toggle.setAttribute('aria-expanded', String(isOpen));
            toggle.setAttribute('aria-label', isOpen ? 'Cerrar menú' : 'Abrir menú de navegación');
        });
    }
    if (backdrop) {
        backdrop.addEventListener('click', () => {
            sidebar.classList.remove('is-open');
            backdrop.classList.remove('is-visible');
            if (toggle) {
                toggle.setAttribute('aria-expanded', 'false');
                toggle.setAttribute('aria-label', 'Abrir menú de navegación');
            }
        });
    }

    // Cerrar sidebar con tecla Escape (WCAG 2.1.1)
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && sidebar && sidebar.classList.contains('is-open')) {
            sidebar.classList.remove('is-open');
            backdrop.classList.remove('is-visible');
            if (toggle) {
                toggle.setAttribute('aria-expanded', 'false');
                toggle.focus();
            }
        }
    });

    // User menu
    if (userBtn && userMenu) {
        const toggleUserMenu = () => {
            const isOpen = userMenu.classList.toggle('is-open');
            userBtn.setAttribute('aria-expanded', String(isOpen));
        };

        userBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            toggleUserMenu();
        });
        userBtn.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                toggleUserMenu();
            }
        });
        document.addEventListener('click', (e) => {
            if (!userMenu.contains(e.target) && !userBtn.contains(e.target)) {
                userMenu.classList.remove('is-open');
                userBtn.setAttribute('aria-expanded', 'false');
            }
        });
    }
})();
</script>