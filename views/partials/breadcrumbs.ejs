<% /* ============================================================
    Partial: breadcrumbs
    Uso: include('../partials/breadcrumbs', { items: [
        { label: 'Reportes', href: '/reportes' },
        { label: 'Productos' } // sin href = elemento actual
    ]})
    ============================================================ */ %>
<% if (typeof items !== 'undefined' && items.length > 0) { %>
<nav class="rp-breadcrumb" aria-label="Ruta de navegación">
    <a href="/" aria-label="Inicio"><i class="bi bi-house-door" aria-hidden="true"></i></a>
    <% items.forEach((item, i) => { %>
        <span class="sep" aria-hidden="true"><i class="bi bi-chevron-right"></i></span>
        <% if (item.href && i < items.length - 1) { %>
            <a href="<%= item.href %>"><%= item.label %></a>
        <% } else { %>
            <span class="current" aria-current="page"><%= item.label %></span>
        <% } %>
    <% }); %>
</nav>
<% } %>