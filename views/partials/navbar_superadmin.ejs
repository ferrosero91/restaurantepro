<%
const currentPath = (typeof locals.currentPath !== 'undefined') ? locals.currentPath : '';
// user puede venir como variable del render o desde res.locals.currentUser
const u = (typeof user !== 'undefined' && user) ? user : (locals.currentUser || {});

const navItems = [
    { href: '/superadmin', icon: 'bi-speedometer2', label: 'Dashboard' },
    { href: '/superadmin/restaurantes', icon: 'bi-building', label: 'Restaurantes' },
    { href: '/superadmin/usuarios', icon: 'bi-people', label: 'Usuarios' },
    { href: '/superadmin/reportes', icon: 'bi-graph-up', label: 'Reportes' },
    { href: '/superadmin/facturacion', icon: 'bi-receipt', label: 'Facturación' },
    { href: '/superadmin/auditoria', icon: 'bi-journal-text', label: 'Auditoría' },
    { href: '/superadmin/api-tokens', icon: 'bi-key', label: 'API Tokens' },
];
%>

<!-- Toggle botón — solo móvil -->
<button class="rp-sidebar-toggle" id="sidebarToggle" aria-label="Abrir menú">
    <i class="bi bi-list"></i>
</button>

<!-- Backdrop — solo móvil -->
<div class="rp-sidebar-backdrop" id="sidebarBackdrop"></div>

<!-- Sidebar -->
<aside class="rp-sidebar" id="sidebar">
    <a class="rp-sidebar-brand" href="/superadmin">
        <i class="bi bi-shield-check"></i>
        <span>SuperAdmin</span>
    </a>

    <ul class="rp-sidebar-nav">
        <% navItems.forEach(item => { %>
            <li class="rp-sidebar-item">
                <a href="<%= item.href %>"
                   class="rp-sidebar-link<%= currentPath === item.href ? ' is-active' : '' %>"
                   data-page="<%= item.href %>">
                    <i class="bi <%= item.icon %>"></i>
                    <span><%= item.label %></span>
                </a>
            </li>
        <% }); %>
    </ul>

    <div class="rp-sidebar-footer">
        <div class="rp-sidebar-user" id="sidebarUserToggle" role="button" tabindex="0" aria-expanded="false" aria-controls="sidebarUserMenu">
            <div class="rp-user-avatar"><i class="bi bi-person"></i></div>
            <div class="rp-user-info">
                <div class="rp-user-name"><%= u.nombre || 'SuperAdmin' %></div>
                <div class="rp-user-role"><%= u.rol || 'superadmin' %></div>
            </div>
            <i class="bi bi-chevron-up" style="font-size:0.7rem; opacity:0.5;"></i>
        </div>
        <ul class="rp-sidebar-user-menu" id="sidebarUserMenu">
            <li><a href="/logout"><i class="bi bi-box-arrow-right"></i> Cerrar Sesión</a></li>
        </ul>
    </div>
</aside>

<!-- Scripts del sidebar — se inyectan al final del body si layout.ejs incluye el partial -->
<script>
(function() {
    const sidebar   = document.getElementById('sidebar');
    const toggle    = document.getElementById('sidebarToggle');
    const backdrop  = document.getElementById('sidebarBackdrop');
    const userBtn   = document.getElementById('sidebarUserToggle');
    const userMenu  = document.getElementById('sidebarUserMenu');

    if (toggle && sidebar) {
        toggle.addEventListener('click', () => {
            sidebar.classList.toggle('is-open');
            backdrop.classList.toggle('is-visible');
        });
    }
    if (backdrop) {
        backdrop.addEventListener('click', () => {
            sidebar.classList.remove('is-open');
            backdrop.classList.remove('is-visible');
        });
    }
    if (userBtn && userMenu) {
        userBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            const open = userMenu.classList.toggle('is-open');
            userBtn.setAttribute('aria-expanded', open);
        });
        document.addEventListener('click', (e) => {
            if (!userMenu.contains(e.target) && !userBtn.contains(e.target)) {
                userMenu.classList.remove('is-open');
                userBtn.setAttribute('aria-expanded', 'false');
            }
        });
    }
})();
</script>
