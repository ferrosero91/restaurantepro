        // --- Facturar domicilio (Requirement 9.8) ---
        async function facturarDomicilio(pedidoId) {
            try {
                // Obtener detalles del pedido para mostrar total
                const response = await fetch(`/domicilios/${pedidoId}`);
                const data = await response.json();
                if (!data.success) {
                    Swal.fire('Error', 'No se pudo obtener el pedido', 'error');
                    return;
                }

                const pedido = data.pedido;
                const total = parseFloat(pedido.total) || 0;

                if (total <= 0) {
                    Swal.fire('Error', 'El pedido no tiene un total válido', 'error');
                    return;
                }

                // Usar el cliente del pedido directamente
                const clienteId = pedido.cliente_id;
                if (!clienteId) {
                    Swal.fire('Error', 'El pedido no tiene un cliente asociado', 'error');
                    return;
                }

                // Mostrar modal de pago con SweetAlert2
                const pagos = await pedirPagosDomicilio(total, pedido);
                if (!pagos) return; // Cancelado

                // Enviar facturación
                const factResp = await fetch(`/domicilios/${pedidoId}/facturar`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ cliente_id: clienteId, pagos })
                });
                const factData = await factResp.json();

                if (!factResp.ok) {
                    throw new Error(factData.error || 'Error al facturar');
                }

                // Redirigir a impresión de factura con retorno a domicilios
                window.location.href = `/api/facturas/${factData.id}/imprimir?return_to=${encodeURIComponent('/domicilios')}`;
            } catch (error) {
                console.error('Error al facturar domicilio:', error);
                Swal.fire('Error', error.message || 'Error al facturar', 'error');
            }
        }

        // Modal de pagos para domicilios (mismo patrón que mesas)
        function parseMoneyInput(value) {
            const v = String(value ?? '').trim();
            if (!v) return 0;
            let normalized = v.replace(/\s/g, '');
            const hasComma = normalized.includes(',');
            const hasDot = normalized.includes('.');
            if (hasComma && hasDot) {
                normalized = normalized.replace(/,/g, '');
            } else if (hasComma && !hasDot) {
                normalized = normalized.replace(/,/g, '.');
            }
            normalized = normalized.replace(/[^\d.-]/g, '');
            const n = Number(normalized);
            return Number.isFinite(n) ? n : 0;
        }

        function formatMoney(n) {
            return `$${Number(n || 0).toLocaleString('es-CO', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
        }

        function almostEqualMoney(a, b) {
            return Math.abs(Number(a) - Number(b)) < 0.01;
        }

        async function pedirPagosDomicilio(total, pedido) {
            const result = await Swal.fire({
