<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Domicilios</title>
    <link href="/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
    <link rel="stylesheet" href="/static/css/theme.css">
    <style>
        html, body { height: 100%; }
        body { min-height: 100vh; display: flex; flex-direction: column; background-color: #f8f9fa; }
        .domicilios-toolbar {
            background: #ffffff;
            border: 1px solid rgba(0,0,0,.06);
            box-shadow: 0 .25rem .75rem rgba(0,0,0,.04);
            border-radius: .75rem;
            padding: .75rem;
        }
        .pedido-card {
            border: 1px solid rgba(0,0,0,.06);
            border-radius: .9rem;
            box-shadow: 0 .4rem 1rem rgba(0,0,0,.05);
            background: #fff;
            transition: transform .1s;
        }
        .pedido-card:hover { transform: translateY(-2px); }
        .estado-pendiente { border-left: 4px solid #ffc107; }
        .estado-confirmado { border-left: 4px solid #0d6efd; }
        .estado-en_preparacion { border-left: 4px solid #fd7e14; }
        .estado-en_camino { border-left: 4px solid #6f42c1; }
        .estado-entregado { border-left: 4px solid #198754; }
        .estado-cancelado { border-left: 4px solid #dc3545; }
        .badge-pendiente { background-color: #ffc107; color: #000; }
        .badge-confirmado { background-color: #0d6efd; color: #fff; }
        .badge-en_preparacion { background-color: #fd7e14; color: #fff; }
        .badge-en_camino { background-color: #6f42c1; color: #fff; }
        .badge-entregado { background-color: #198754; color: #fff; }
        .badge-cancelado { background-color: #dc3545; color: #fff; }
        .tiempo-alerta { color: #dc3545; font-weight: 700; }
        .empty-state {
            border: 1px dashed rgba(0,0,0,.15);
            border-radius: .9rem;
            background: #fff;
            padding: 2rem;
            color: #6c757d;
            text-align: center;
        }
        .filter-btn.active { font-weight: 600; }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="rp-content">

    <main class="flex-grow-1">
    <div class="container">
        <!-- Header -->
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <div>
                <h4 class="mb-0"><i class="bi bi-truck me-2"></i>Domicilios</h4>
                <div class="text-muted small">Gestión de pedidos a domicilio</div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <button id="btnNuevoPedido" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i>Nuevo Pedido
                </button>
                <button id="btnRefresh" class="btn btn-outline-secondary btn-sm" type="button">
                    <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
                </button>
                <div class="form-check form-switch m-0">
                    <input class="form-check-input" type="checkbox" role="switch" id="toggleAutoRefresh" checked>
                    <label class="form-check-label small" for="toggleAutoRefresh">Auto</label>
                </div>
            </div>
        </div>

        <!-- Toolbar: Filtros y KPIs -->
        <div class="domicilios-toolbar mb-3">
            <div class="row g-2 align-items-center">
                <div class="col-12 col-md-8">
                    <div class="d-flex flex-wrap gap-2" id="filtrosEstado">
                        <button class="btn btn-sm btn-outline-secondary filter-btn active" data-estado="">
                            <i class="bi bi-list-ul me-1"></i>Todos
                        </button>
                        <button class="btn btn-sm btn-outline-warning filter-btn" data-estado="pendiente">
                            <i class="bi bi-clock me-1"></i>Pendientes
                        </button>
                        <button class="btn btn-sm btn-outline-primary filter-btn" data-estado="confirmado">
                            <i class="bi bi-check-circle me-1"></i>Confirmados
                        </button>
                        <button class="btn btn-sm btn-outline-orange filter-btn" data-estado="en_preparacion" style="border-color:#fd7e14;color:#fd7e14;">
                            <i class="bi bi-fire me-1"></i>En Preparación
                        </button>
                        <button class="btn btn-sm btn-outline-purple filter-btn" data-estado="en_camino" style="border-color:#6f42c1;color:#6f42c1;">
                            <i class="bi bi-bicycle me-1"></i>En Camino
                        </button>
                        <button class="btn btn-sm btn-outline-success filter-btn" data-estado="entregado">
                            <i class="bi bi-check2-all me-1"></i>Entregados
                        </button>
                        <button class="btn btn-sm btn-outline-danger filter-btn" data-estado="cancelado">
                            <i class="bi bi-x-circle me-1"></i>Cancelados
                        </button>
                    </div>
                </div>
                <div class="col-12 col-md-4 d-flex justify-content-md-end gap-2">
                    <span class="badge text-bg-warning">Pendientes: <span id="countPendientes">0</span></span>
                    <span class="badge text-bg-primary">En curso: <span id="countEnCurso">0</span></span>
                    <span class="badge text-bg-success">Entregados: <span id="countEntregados">0</span></span>
                </div>
            </div>
        </div>

        <!-- Lista de pedidos -->
        <div id="emptyState" class="empty-state d-none">
            <i class="bi bi-truck" style="font-size: 3rem;"></i>
            <p class="mt-2 mb-0">No hay pedidos a domicilio</p>
            <small class="text-muted">Los pedidos aparecerán aquí cuando se creen</small>
        </div>

        <!-- Tabla responsive para pantallas grandes -->
        <div id="tablaPedidos" class="d-none d-lg-block">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Cliente</th>
                            <th>Dirección</th>
                            <th>Teléfono</th>
                            <th>Estado</th>
                            <th>Tiempo</th>
                            <th>Total</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="tbodyPedidos"></tbody>
                </table>
            </div>
        </div>

        <!-- Cards para móvil -->
        <div id="cardsPedidos" class="d-lg-none vstack gap-3"></div>
    </div>

    <!-- Modal Nuevo Pedido (Fullscreen Táctil) -->
    <div class="modal fade" id="modalNuevoPedido" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-fullscreen">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white py-2">
                    <h5 class="modal-title"><i class="bi bi-truck me-2"></i>Nuevo Pedido a Domicilio</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="row g-0" style="height: calc(100vh - 56px);">
                        <!-- Panel Izquierdo: Productos -->
                        <div class="col-12 col-md-7 border-end" style="overflow-y: auto;">
                            <div class="p-3">
                                <div class="input-group mb-3">
                                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                                    <input id="dlvBuscarProducto" class="form-control" placeholder="Buscar producto..." autocomplete="off">
                                </div>
                                <div class="d-flex gap-2 flex-wrap mb-3" id="dlvCategorias">
                                    <button class="btn btn-sm btn-primary" data-cat="">Todos</button>
                                </div>
                                <div class="row g-2" id="dlvGridProductos">
                                    <div class="col-12 text-center text-muted py-4">Cargando productos...</div>
                                </div>
                            </div>
                        </div>

                        <!-- Panel Derecho: Cliente + Carrito -->
                        <div class="col-12 col-md-5 d-flex flex-column bg-light" style="overflow-y: auto;">
                            <!-- Datos del cliente -->
                            <div class="p-3 border-bottom bg-white">
                                <h6 class="fw-bold mb-2"><i class="bi bi-person me-1"></i>Cliente</h6>
                                <div class="input-group mb-2">
                                    <input type="text" class="form-control form-control-sm" id="dlvBuscarCliente" placeholder="Buscar por nombre o teléfono..." autocomplete="off">
                                    <button class="btn btn-outline-success btn-sm" type="button" id="dlvBtnCrearCliente" title="Crear cliente nuevo">
                                        <i class="bi bi-person-plus"></i>
                                    </button>
                                </div>
                                <div id="dlvClienteResultados" class="list-group mb-2" style="max-height:100px;overflow-y:auto;display:none;"></div>
                                <div id="dlvClienteInfo" style="display:none;" class="small bg-light rounded p-2">
                                    <strong id="dlvClienteNombre"></strong>
                                    <span class="text-muted ms-2" id="dlvClienteTel"></span>
                                    <input type="hidden" id="dlvClienteId">
                                </div>
                                <div class="row g-2 mt-1">
                                    <div class="col-12">
                                        <input type="text" class="form-control form-control-sm" id="dlvDireccion" placeholder="Dirección de entrega *" required>
                                    </div>
                                    <div class="col-6">
                                        <input type="text" class="form-control form-control-sm" id="dlvTelefono" placeholder="Teléfono *" required>
                                    </div>
                                    <div class="col-6">
                                        <input type="text" class="form-control form-control-sm" id="dlvNotas" placeholder="Notas entrega">
                                    </div>
                                </div>
                            </div>

                            <!-- Items del pedido -->
                            <div class="flex-grow-1 p-3 overflow-auto">
                                <h6 class="fw-bold mb-2"><i class="bi bi-cart3 me-1"></i>Productos</h6>
                                <div id="dlvItemsList">
                                    <div class="text-center text-muted py-3"><i class="bi bi-inbox" style="font-size:2rem;"></i><p class="mt-1 small">Agrega productos del menú</p></div>
                                </div>
                            </div>

                            <!-- Totales y acciones -->
                            <div class="p-3 border-top bg-white">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span>Subtotal:</span><strong id="dlvSubtotal">$0</strong>
                                </div>
                                <div class="d-flex justify-content-between small mb-1 align-items-center">
                                    <span>Domicilio:</span>
                                    <input type="number" class="form-control form-control-sm text-end" id="dlvValorDomicilio" value="0" min="0" style="width:100px;">
                                </div>
                                <div class="d-flex justify-content-between small mb-2 align-items-center">
                                    <span>Propina:</span>
                                    <div class="d-flex gap-1" id="dlvPropinaBtns"></div>
                                    <strong id="dlvPropinaMonto" class="text-success">$0</strong>
                                </div>
                                <div class="d-flex justify-content-between fw-bold fs-5 mb-3 border-top pt-2">
                                    <span>TOTAL:</span><span id="dlvTotal" class="text-primary">$0</span>
                                </div>
                                <button class="btn btn-primary btn-lg w-100" id="dlvBtnCrearPedido">
                                    <i class="bi bi-check-circle me-2"></i>Crear Pedido
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Detalle Pedido -->
    <div class="modal fade" id="modalDetalle" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-info-circle me-2"></i>Detalle del Pedido</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="detalleBody">
                    <!-- Se llena dinámicamente -->
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    </main>
    <script src="/vendor/jquery/jquery.min.js"></script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <script>
    (function() {
        'use strict';

        // --- Estado ---
        let pedidos = [];
        let filtroActual = '';
        let autoRefreshInterval = null;
        const REFRESH_INTERVAL = 15000; // 15 segundos

        // --- Mapas de estados ---
        const ESTADO_LABELS = {
            'pendiente': 'Pendiente',
            'confirmado': 'Confirmado',
            'en_preparacion': 'En Preparación',
            'en_camino': 'En Camino',
            'entregado': 'Entregado',
            'cancelado': 'Cancelado'
        };

        const ESTADO_ICONS = {
            'pendiente': 'bi-clock',
            'confirmado': 'bi-check-circle',
            'en_preparacion': 'bi-fire',
            'en_camino': 'bi-bicycle',
            'entregado': 'bi-check2-all',
            'cancelado': 'bi-x-circle'
        };

        // Transiciones válidas para botones de acción
        const TRANSICIONES = {
            'pendiente': [{ estado: 'confirmado', label: 'Confirmar', icon: 'bi-check-circle', clase: 'btn-primary' }],
            'confirmado': [{ estado: 'en_preparacion', label: 'Preparar', icon: 'bi-fire', clase: 'btn-warning' }],
            'en_preparacion': [{ estado: 'en_camino', label: 'Enviar', icon: 'bi-bicycle', clase: 'btn-purple', style: 'background-color:#6f42c1;border-color:#6f42c1;color:#fff;' }],
            'en_camino': [{ estado: 'entregado', label: 'Entregado', icon: 'bi-check2-all', clase: 'btn-success' }],
            'entregado': [],
            'cancelado': []
        };

        // --- Cargar pedidos ---
        async function cargarPedidos() {
            try {
                const params = new URLSearchParams();
                if (filtroActual) params.set('estado', filtroActual);

                const response = await fetch('/domicilios/listar?' + params.toString());
                const data = await response.json();

                if (data.success) {
                    pedidos = data.pedidos;
                    renderPedidos();
                    actualizarKPIs();
                }
            } catch (error) {
                console.error('Error al cargar pedidos:', error);
            }
        }

        // --- Render pedidos ---
        function renderPedidos() {
            const tbody = document.getElementById('tbodyPedidos');
            const cards = document.getElementById('cardsPedidos');
            const emptyState = document.getElementById('emptyState');
            const tablaPedidos = document.getElementById('tablaPedidos');

            if (pedidos.length === 0) {
                emptyState.classList.remove('d-none');
                tablaPedidos.classList.add('d-none');
                tablaPedidos.classList.remove('d-lg-block');
                cards.innerHTML = '';
                return;
            }

            emptyState.classList.add('d-none');
            tablaPedidos.classList.remove('d-none');
            tablaPedidos.classList.add('d-lg-block');

            // Render tabla (desktop)
            tbody.innerHTML = pedidos.map(p => renderFilaTabla(p)).join('');

            // Render cards (móvil)
            cards.innerHTML = pedidos.map(p => renderCard(p)).join('');
        }

        function renderFilaTabla(p) {
            const estadoBadge = `<span class="badge badge-${p.estado}"><i class="bi ${ESTADO_ICONS[p.estado]} me-1"></i>${ESTADO_LABELS[p.estado]}</span>`;
            const tiempoClase = esTiempoAlerta(p.tiempo_transcurrido) ? 'tiempo-alerta' : '';
            const acciones = renderAcciones(p);

            return `
                <tr class="estado-${p.estado}">
                    <td><strong>#${p.id}</strong></td>
                    <td>${p.cliente_nombre || 'Sin nombre'}</td>
                    <td><small>${p.direccion_entrega || '-'}</small></td>
                    <td>${p.telefono_contacto || p.cliente_telefono || '-'}</td>
                    <td>${estadoBadge}</td>
                    <td class="${tiempoClase}"><i class="bi bi-stopwatch me-1"></i>${p.tiempo_transcurrido}</td>
                    <td>$${formatNumber(p.total)}</td>
                    <td>
                        <div class="d-flex gap-1 flex-wrap">
                            ${acciones}
                            <button class="btn btn-sm btn-outline-secondary" onclick="verDetalle(${p.id})" title="Ver detalle">
                                <i class="bi bi-eye"></i>
                            </button>
                            ${p.estado !== 'entregado' && p.estado !== 'cancelado' ? `
                            <button class="btn btn-sm btn-outline-danger" onclick="cancelarPedido(${p.id})" title="Cancelar">
                                <i class="bi bi-x-lg"></i>
                            </button>` : ''}
                        </div>
                    </td>
                </tr>
            `;
        }

        function renderCard(p) {
            const estadoBadge = `<span class="badge badge-${p.estado}"><i class="bi ${ESTADO_ICONS[p.estado]} me-1"></i>${ESTADO_LABELS[p.estado]}</span>`;
            const tiempoClase = esTiempoAlerta(p.tiempo_transcurrido) ? 'tiempo-alerta' : '';
            const acciones = renderAcciones(p);

            return `
                <div class="pedido-card p-3 estado-${p.estado}">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <strong>#${p.id}</strong> - ${p.cliente_nombre || 'Sin nombre'}
                        </div>
                        ${estadoBadge}
                    </div>
                    <div class="small text-muted mb-2">
                        <div><i class="bi bi-geo-alt me-1"></i>${p.direccion_entrega || '-'}</div>
                        <div><i class="bi bi-telephone me-1"></i>${p.telefono_contacto || p.cliente_telefono || '-'}</div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="${tiempoClase}"><i class="bi bi-stopwatch me-1"></i>${p.tiempo_transcurrido}</span>
                        <strong>$${formatNumber(p.total)}</strong>
                    </div>
                    <div class="d-flex gap-1 mt-2 flex-wrap">
                        ${acciones}
                        <button class="btn btn-sm btn-outline-secondary" onclick="verDetalle(${p.id})">
                            <i class="bi bi-eye me-1"></i>Detalle
                        </button>
                        ${p.estado !== 'entregado' && p.estado !== 'cancelado' ? `
                        <button class="btn btn-sm btn-outline-danger" onclick="cancelarPedido(${p.id})">
                            <i class="bi bi-x-lg me-1"></i>Cancelar
                        </button>` : ''}
                    </div>
                </div>
            `;
        }

        function renderAcciones(p) {
            const transiciones = TRANSICIONES[p.estado] || [];
            let html = transiciones.map(t => `
                <button class="btn btn-sm ${t.clase}" ${t.style ? `style="${t.style}"` : ''} onclick="cambiarEstado(${p.id}, '${t.estado}')">
                    <i class="bi ${t.icon} me-1"></i>${t.label}
                </button>
            `).join('');

            // Botón Facturar para pedidos entregados (Requirement 9.8)
            if (p.estado === 'entregado') {
                html += `
                <button class="btn btn-sm btn-success" onclick="facturarDomicilio(${p.id})" title="Facturar pedido">
                    <i class="bi bi-cash-coin me-1"></i>Facturar
                </button>`;
            }

            return html;
        }

        // --- Acciones ---
        async function cambiarEstado(pedidoId, nuevoEstado) {
            try {
                const response = await fetch(`/domicilios/${pedidoId}/estado`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ estado: nuevoEstado })
                });
                const data = await response.json();

                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Estado actualizado',
                        text: `Pedido #${pedidoId} → ${ESTADO_LABELS[nuevoEstado]}`,
                        timer: 1500,
                        showConfirmButton: false
                    });
                    cargarPedidos();
                } else {
                    Swal.fire('Error', data.error || 'No se pudo actualizar el estado', 'error');
                }
            } catch (error) {
                console.error('Error al cambiar estado:', error);
                Swal.fire('Error', 'Error de conexión', 'error');
            }
        }

        async function cancelarPedido(pedidoId) {
            const result = await Swal.fire({
                title: '¿Cancelar pedido?',
                text: `¿Está seguro de cancelar el pedido #${pedidoId}?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                confirmButtonText: 'Sí, cancelar',
                cancelButtonText: 'No'
            });

            if (result.isConfirmed) {
                cambiarEstado(pedidoId, 'cancelado');
            }
        }

        async function verDetalle(pedidoId) {
            try {
                const response = await fetch(`/domicilios/${pedidoId}`);
                const data = await response.json();

                if (data.success) {
                    const p = data.pedido;
                    const itemsHtml = (p.items || []).map(item => `
                        <tr>
                            <td>${item.producto_nombre}</td>
                            <td>${item.cantidad} ${item.unidad_medida}</td>
                            <td>$${formatNumber(item.subtotal)}</td>
                        </tr>
                    `).join('');

                    // Construir historial de estados
                    const historialHtml = renderHistorialEstados(p.historial_estados || [], p);

                    document.getElementById('detalleBody').innerHTML = `
                        <div class="mb-3">
                            <span class="badge badge-${p.estado}"><i class="bi ${ESTADO_ICONS[p.estado]} me-1"></i>${ESTADO_LABELS[p.estado]}</span>
                            <span class="ms-2 text-muted small"><i class="bi bi-stopwatch me-1"></i>${p.tiempo_transcurrido}</span>
                        </div>
                        <div class="row g-2 mb-3">
                            <div class="col-6"><strong>Cliente:</strong><br>${p.cliente_nombre || '-'}</div>
                            <div class="col-6"><strong>Teléfono:</strong><br>${p.telefono_contacto || '-'}</div>
                            <div class="col-12"><strong>Dirección:</strong><br>${p.direccion_entrega || '-'}</div>
                            ${p.notas_entrega ? `<div class="col-12"><strong>Notas:</strong><br>${p.notas_entrega}</div>` : ''}
                            ${p.hora_entrega_estimada ? `<div class="col-6"><strong>Hora estimada:</strong><br>${p.hora_entrega_estimada}</div>` : ''}
                        </div>
                        <h6>Items del pedido</h6>
                        <table class="table table-sm">
                            <thead><tr><th>Producto</th><th>Cantidad</th><th>Subtotal</th></tr></thead>
                            <tbody>${itemsHtml || '<tr><td colspan="3" class="text-muted">Sin items</td></tr>'}</tbody>
                            <tfoot><tr><td colspan="2" class="text-end fw-bold">Total:</td><td class="fw-bold">$${formatNumber(p.total)}</td></tr></tfoot>
                        </table>
                        ${historialHtml}
                    `;

                    new bootstrap.Modal(document.getElementById('modalDetalle')).show();
                }
            } catch (error) {
                console.error('Error al ver detalle:', error);
                Swal.fire('Error', 'No se pudo cargar el detalle', 'error');
            }
        }

        // Renderizar historial de cambios de estado como timeline
        function renderHistorialEstados(historial, pedido) {
            if (!historial || historial.length === 0) {
                // Fallback: mostrar al menos la creación
                return `
                    <h6 class="mt-3"><i class="bi bi-clock-history me-1"></i>Historial de Estados</h6>
                    <div class="small text-muted">
                        <div class="d-flex align-items-center gap-2 py-1">
                            <span class="badge badge-pendiente"><i class="bi bi-clock me-1"></i>Pendiente</span>
                            <span>${formatFechaHora(pedido.created_at)}</span>
                        </div>
                    </div>
                `;
            }

            const items = historial.map((h, idx) => {
                const esUltimo = idx === historial.length - 1;
                const estadoLabel = ESTADO_LABELS[h.estado] || h.estado;
                const estadoIcon = ESTADO_ICONS[h.estado] || 'bi-circle';
                const badgeClass = `badge-${h.estado}`;

                return `
                    <div class="d-flex align-items-start gap-2 py-1 ${esUltimo ? 'fw-semibold' : ''}">
                        <div class="d-flex flex-column align-items-center" style="min-width: 12px;">
                            <i class="bi ${esUltimo ? 'bi-circle-fill' : 'bi-circle'}" style="font-size: 0.5rem; color: ${getEstadoColor(h.estado)};"></i>
                            ${idx < historial.length - 1 ? '<div style="width: 1px; height: 16px; background: #dee2e6;"></div>' : ''}
                        </div>
                        <div class="flex-grow-1">
                            <span class="badge ${badgeClass} me-1" style="font-size: 0.7rem;"><i class="bi ${estadoIcon} me-1"></i>${estadoLabel}</span>
                            <span class="text-muted small">${formatFechaHora(h.fecha)}</span>
                        </div>
                    </div>
                `;
            }).join('');

            return `
                <h6 class="mt-3"><i class="bi bi-clock-history me-1"></i>Historial de Estados</h6>
                <div class="small">${items}</div>
            `;
        }

        // Obtener color del estado para el timeline
        function getEstadoColor(estado) {
            const colores = {
                'pendiente': '#ffc107',
                'confirmado': '#0d6efd',
                'en_preparacion': '#fd7e14',
                'en_camino': '#6f42c1',
                'entregado': '#198754',
                'cancelado': '#dc3545'
            };
            return colores[estado] || '#6c757d';
        }

        // Formatear fecha y hora para el historial
        function formatFechaHora(fecha) {
            if (!fecha) return '-';
            const d = new Date(fecha);
            if (isNaN(d.getTime())) return '-';
            return d.toLocaleString('es-CO', {
                day: '2-digit',
                month: '2-digit',
                year: 'numeric',
                hour: '2-digit',
                minute: '2-digit'
            });
        }

        // --- KPIs ---
        function actualizarKPIs() {
            // Contar todos los pedidos sin filtro para KPIs
            const pendientes = pedidos.filter(p => p.estado === 'pendiente').length;
            const enCurso = pedidos.filter(p => ['confirmado', 'en_preparacion', 'en_camino'].includes(p.estado)).length;
            const entregados = pedidos.filter(p => p.estado === 'entregado').length;

            document.getElementById('countPendientes').textContent = pendientes;
            document.getElementById('countEnCurso').textContent = enCurso;
            document.getElementById('countEntregados').textContent = entregados;
        }

        // --- Utilidades ---
        function esTiempoAlerta(tiempo) {
            if (!tiempo) return false;
            const match = tiempo.match(/(\d+)h/);
            if (match && parseInt(match[1]) >= 1) return true;
            const minMatch = tiempo.match(/^(\d+)min$/);
            if (minMatch && parseInt(minMatch[1]) >= 45) return true;
            return false;
        }

        function formatNumber(num) {
            if (!num) return '0';
            return parseFloat(num).toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
        }

        // --- Filtros ---
        document.getElementById('filtrosEstado').addEventListener('click', function(e) {
            const btn = e.target.closest('.filter-btn');
            if (!btn) return;

