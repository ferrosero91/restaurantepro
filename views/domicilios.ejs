        function renderDlvGrid(catFilter = '') {
            const el = document.getElementById('dlvGridProductos');
            const busqueda = document.getElementById('dlvBuscarProducto').value.toLowerCase().trim();
            let prods = dlvProductos.filter(p => p.activo !== 0);
            if (catFilter) prods = prods.filter(p => (p.categoria_nombre || 'Sin categoría') === catFilter);
            if (busqueda) prods = prods.filter(p => p.nombre.toLowerCase().includes(busqueda) || (p.codigo || '').toLowerCase().includes(busqueda));

            if (prods.length === 0) {
                el.innerHTML = '<div class="col-12 text-center text-muted py-4">No hay productos</div>';
                return;
            }
            el.innerHTML = prods.map(p => {
                const precio = p.precio_unidad || p.precio_kg || p.precio_libra || 0;
                const img = p.imagen ? `<img src="${p.imagen}" class="card-img-top" style="height:100px;object-fit:cover;">` : `<div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height:100px;"><i class="bi bi-image text-muted" style="font-size:2rem;"></i></div>`;
                return `<div class="col-6 col-md-4 col-lg-3"><div class="card h-100 shadow-sm" style="cursor:pointer;" onclick="dlvAgregarProducto(${p.id})">${img}<div class="card-body p-2"><div class="small fw-bold text-truncate">${p.nombre}</div><div class="text-primary fw-bold small">$${formatNumber(precio)}</div></div></div></div>`;
            }).join('');
        }

        document.getElementById('dlvBuscarProducto').addEventListener('input', function() { renderDlvGrid(document.querySelector('.dlv-cat-btn.btn-primary')?.dataset.cat || ''); });

        window.dlvAgregarProducto = function(productoId) {
            const p = dlvProductos.find(x => x.id === productoId);
            if (!p) return;
            const precio = p.precio_unidad || p.precio_kg || p.precio_libra || 0;
            const unidad = p.precio_unidad ? 'UND' : p.precio_kg ? 'KG' : 'LB';
            dlvItems.push({ producto_id: p.id, nombre: p.nombre, cantidad: 1, unidad_medida: unidad, precio, subtotal: precio, nota: '' });
            renderDlvItems();
            renderDlvTotals();
        };

        function renderDlvItems() {
            const el = document.getElementById('dlvItemsList');
            if (dlvItems.length === 0) {
                el.innerHTML = '<div class="text-center text-muted py-3"><i class="bi bi-inbox" style="font-size:2rem;"></i><p class="mt-1 small">Agrega productos del menú</p></div>';
                return;
            }
            el.innerHTML = dlvItems.map((item, idx) => `
                <div class="d-flex align-items-center gap-2 p-2 mb-2 border rounded bg-white">
                    <div class="flex-grow-1">
                        <div class="small fw-bold">${item.nombre}</div>
                        <div class="d-flex gap-1 align-items-center mt-1">
                            <input type="number" class="form-control form-control-sm" style="width:55px;" value="${item.cantidad}" min="1" onchange="dlvUpdateItem(${idx},'cantidad',this.value)">
                            <span class="text-muted small">${item.unidad_medida}</span>
                            <span class="text-muted small">×</span>
                            <input type="number" class="form-control form-control-sm" style="width:80px;" value="${item.precio}" min="0" onchange="dlvUpdateItem(${idx},'precio',this.value)">
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="fw-bold small">$${formatNumber(item.subtotal)}</div>
                        <button class="btn btn-sm btn-outline-danger mt-1" onclick="dlvRemoveItem(${idx})"><i class="bi bi-trash3"></i></button>
                    </div>
                </div>
            `).join('');
        }

        window.dlvUpdateItem = function(idx, field, val) {
            if (field === 'cantidad') { dlvItems[idx].cantidad = parseFloat(val) || 1; }
            if (field === 'precio') { dlvItems[idx].precio = parseFloat(val) || 0; }
            dlvItems[idx].subtotal = dlvItems[idx].cantidad * dlvItems[idx].precio;
            renderDlvItems();
            renderDlvTotals();
        };
        window.dlvRemoveItem = function(idx) { dlvItems.splice(idx, 1); renderDlvItems(); renderDlvTotals(); };

        function renderDlvTotals() {
            const subtotal = dlvItems.reduce((s, i) => s + i.subtotal, 0);
            const domicilio = parseFloat(document.getElementById('dlvValorDomicilio').value) || 0;
            const total = subtotal + domicilio + dlvPropina;
            document.getElementById('dlvSubtotal').textContent = '$' + formatNumber(subtotal);
            document.getElementById('dlvPropinaMonto').textContent = '$' + formatNumber(dlvPropina);
            document.getElementById('dlvTotal').textContent = '$' + formatNumber(total);
        }
        document.getElementById('dlvValorDomicilio').addEventListener('input', renderDlvTotals);

        async function cargarDlvPropinas() {
            try {
                const resp = await fetch('/api/facturas/tip-config');
                if (!resp.ok) return;
                const cfg = await resp.json();
                const el = document.getElementById('dlvPropinaBtns');
