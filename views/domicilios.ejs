                el.innerHTML = (cfg.percentages || []).map(pct => `<button class="btn btn-outline-success btn-sm dlv-tip-btn" onclick="dlvSetPropina(${pct})">${pct}%</button>`).join('') + '<button class="btn btn-outline-secondary btn-sm" onclick="dlvSetPropina(0)">Sin</button>';
            } catch(e) {}
        }
        window.dlvSetPropina = function(pct) {
            const subtotal = dlvItems.reduce((s, i) => s + i.subtotal, 0);
            dlvPropina = pct > 0 ? Math.round(subtotal * pct / 100) : 0;
